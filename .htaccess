# AXIO — Apache config for shared hosting (Timeweb/Reg.ru).
# The site is fully static; routes are directories with index.html, so
# clean URLs (/seo) work out of the box. This file adds HTTPS, canonical
# host, a custom 404 and sensible caching.

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Canonical host: redirect apex → www (matches canonical/SEO setup).
  # If you prefer apex (no www), swap the two lines below.
  RewriteCond %{HTTP_HOST} ^axioagency\.ru$ [NC]
  RewriteRule ^ https://www.axioagency.ru%{REQUEST_URI} [L,R=301]

  # Strip trailing slash (except root) to match canonical (trailingSlash:never).
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+)/$ /$1 [L,R=301]
</IfModule>

# Don't let Apache auto-append a trailing slash to directory URLs.
<IfModule mod_dir.c>
  DirectorySlash Off
</IfModule>

# Serve index.html for directory requests (clean URLs).
DirectoryIndex index.html

# Custom 404
ErrorDocument 404 /404.html

# Caching: long for hashed assets/images, short for HTML.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Gzip/Brotli compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml application/json
</IfModule>
