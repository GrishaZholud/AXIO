---
// Animated hero background: flowing golden "wave" lines on a warm-dark
// radial gradient (canvas). Sits behind hero content. Respects
// prefers-reduced-motion (renders a single static frame, no loop).
---

<div class="axio-bg" aria-hidden="true">
  <canvas data-axio-canvas></canvas>
</div>

<style>
  .axio-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    background: radial-gradient(120% 95% at 50% 8%, #18130d 0%, #0d0b08 55%, #080604 100%);
  }
  .axio-bg canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
  .axio-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(50% 48% at 36% 44%, rgba(214, 176, 120, 0.14), transparent 62%),
      radial-gradient(125% 108% at 50% 40%, transparent 36%, rgba(0, 0, 0, 0.6) 100%);
  }
</style>

<script>
  (function () {
    const cv = document.querySelector<HTMLCanvasElement>('[data-axio-canvas]');
    if (!cv) return;
    const ctx = cv.getContext('2d');
    if (!ctx) return;

    const dpr = Math.min(window.devicePixelRatio || 1, 1.5);
    let W = 0;
    let H = 0;
    let raf = 0;
    let inView = true;

    function resize() {
      const r = cv.getBoundingClientRect();
      W = r.width;
      H = r.height;
      cv.width = W * dpr;
      cv.height = H * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resize();
    window.addEventListener('resize', resize, { passive: true });

    const LINES = 40;
    const focalY = 0.44;

    function draw(now: number) {
      // Keep animating even while scrolling; only stop once off-screen.
      if (!inView) {
        raf = 0;
        return;
      }
      const t = now * 0.00045;
      ctx.clearRect(0, 0, W, H);
      ctx.globalCompositeOperation = 'lighter';
      ctx.lineWidth = 1.15;
      for (let i = 0; i < LINES; i++) {
        const p = i / (LINES - 1);
        const baseY = p * H * 1.06 - H * 0.03;
        const amp = 22 + 20 * Math.sin(i * 0.37 + 1.2);
        const dist = Math.abs(p - focalY);
        const a = Math.max(0, 1 - dist * 2.6);
        if (a <= 0.001) continue;
        ctx.beginPath();
        for (let x = -20; x <= W + 20; x += 7) {
          const y =
            baseY +
            amp * Math.sin(x * 0.0055 + t + i * 0.33) +
            amp * 0.4 * Math.sin(x * 0.013 - t * 1.4 + i * 0.6);
          if (x === -20) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        const g = ctx.createLinearGradient(0, 0, W, 0);
        const v = a * 0.5;
        g.addColorStop(0, `rgba(231,205,160,${v})`);
        g.addColorStop(0.55, `rgba(195,159,111,${v * 0.8})`);
        g.addColorStop(1, `rgba(150,116,70,${v * 0.45})`);
        ctx.strokeStyle = g;
        ctx.shadowColor = `rgba(214,176,120,${a * 0.45})`;
        ctx.shadowBlur = 6;
        ctx.stroke();
      }
      ctx.shadowBlur = 0;
      ctx.globalCompositeOperation = 'source-over';
      raf = requestAnimationFrame(draw);
    }

    // Only animate while the hero is on screen (stops once scrolled past).
    const io = new IntersectionObserver(
      ([e]) => {
        inView = e.isIntersecting;
        if (inView && !raf) raf = requestAnimationFrame(draw);
      },
      { threshold: 0 }
    );
    io.observe(cv);

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) {
      draw(0); // one static frame, no loop
      if (raf) cancelAnimationFrame(raf);
      raf = 0;
    } else {
      raf = requestAnimationFrame(draw);
    }
  })();
</script>
