---
import { type CaseStudy, casesAreDemo } from '../data/cases';
import { caseContent } from '../data/caseContent';
export interface Props {
  study: CaseStudy;
}
const { study } = Astro.props;
const cover = caseContent[study.slug]?.cover;
---

<a href={`/cases/${study.slug}`} class="case-card">
  {cover && (
    <div class="case-card__media">
      <img src={cover} alt={study.headline} width="1200" height="675" loading="lazy" decoding="async" />
    </div>
  )}
  <div class="case-card__body">
    <div class="case-card__top">
      <span class="case-card__industry">{study.industry}</span>
      {casesAreDemo && <span class="case-card__demo">Пример</span>}
      <ul class="case-card__tags">
        {study.tags.map((t) => <li>{t}</li>)}
      </ul>
    </div>
    <h3 class="case-card__headline">{study.headline}</h3>
    <p class="case-card__teaser">{study.teaser}</p>
    <dl class="case-card__metrics">
      {
        study.metrics.slice(0, 3).map((m) => (
          <div>
            <dt>{m.value}</dt>
            <dd>{m.label}</dd>
          </div>
        ))
      }
    </dl>
    <span class="case-card__cta link-arrow">
      Смотреть кейс
      <svg width="16" height="16" viewBox="0 0 18 18" aria-hidden="true">
        <path d="M4 9h9M9 5l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </span>
  </div>
</a>

<style>
  .case-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 200ms ease, box-shadow 200ms ease;
  }
  @media (hover: hover) and (pointer: fine) {
    .case-card:hover {
      border-color: var(--gold);
      box-shadow: var(--shadow-md);
    }
  }
  .case-card__media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--surface-2, #f4f1eb);
  }
  .case-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 400ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  @media (hover: hover) and (pointer: fine) {
    .case-card:hover .case-card__media img {
      transform: scale(1.04);
    }
  }
  .case-card__body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.75rem;
    flex: 1;
  }
  .case-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .case-card__industry {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--gold);
    margin-right: auto;
  }
  .case-card__demo {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-muted);
    padding: 0.2rem 0.5rem;
    border: 1px dashed var(--border);
    border-radius: 999px;
  }
  .case-card__tags {
    display: flex;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
  }
  .case-card__tags li {
    font-size: 0.72rem;
    color: var(--fg-muted);
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--border);
    border-radius: 999px;
  }
  .case-card__headline {
    font-size: 1.25rem;
    line-height: 1.25;
    color: var(--fg);
  }
  .case-card__teaser {
    font-size: 0.92rem;
    color: var(--fg-muted);
    line-height: 1.55;
  }
  .case-card__metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-top: auto;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
  }
  .case-card__metrics dt {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--fg);
  }
  .case-card__metrics dd {
    margin: 0.1rem 0 0;
    font-size: 0.78rem;
    color: var(--fg-muted);
    max-width: 14ch;
  }
  .case-card__cta {
    font-size: 0.9rem;
    color: var(--gold);
  }
</style>
