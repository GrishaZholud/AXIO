---
import Icon from './Icon.astro';
import type { Service } from '../data/services';
export interface Props {
  service: Service;
}
const { service } = Astro.props;
---

<a href={`/${service.slug}`} class="service-card">
  <span class="service-card__icon"><Icon name={service.icon} size={22} /></span>
  <span class="service-card__body">
    <span class="service-card__title">{service.label}</span>
    <span class="service-card__desc">{service.short}</span>
  </span>
  <svg class="service-card__arrow" width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
    <path d="M4 9h9M9 5l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
</a>

<style>
  .service-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: border-color 200ms ease, box-shadow 200ms ease;
  }
  @media (hover: hover) and (pointer: fine) {
    .service-card:hover {
      border-color: var(--gold);
      box-shadow: var(--shadow-md);
    }
  }
  .service-card__icon {
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    flex-shrink: 0;
    color: var(--gold-deep);
    background: var(--gold-soft);
    border-radius: 12px;
    transition: background 200ms ease, color 200ms ease;
  }
  .service-card:hover .service-card__icon {
    background: var(--gold);
    color: var(--ink);
  }
  .service-card__body {
    display: grid;
    gap: 0.3rem;
  }
  .service-card__title {
    font-weight: 700;
    font-size: 1.08rem;
    color: var(--ink);
    letter-spacing: -0.02em;
  }
  .service-card__desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.45;
  }
  .service-card__arrow {
    margin-left: auto;
    color: var(--text-faint);
    transition: transform 0.3s var(--ease), color 0.3s var(--ease);
  }
  .service-card:hover .service-card__arrow {
    transform: translateX(3px);
    color: var(--gold-deep);
  }
</style>
