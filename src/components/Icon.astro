---
// Lightweight inline icon set (stroke-based, 24x24). Referenced by `icon`
// ids in services.ts. Inline SVG keeps zero extra requests.
export interface Props {
  name: string;
  size?: number;
  class?: string;
}
const { name, size = 24, class: cls } = Astro.props;

const paths: Record<string, string> = {
  layout: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>',
  code: '<path d="m8 8-4 4 4 4M16 8l4 4-4 4M13.5 5l-3 14"/>',
  rocket:
    '<path d="M14 4c3 0 6 3 6 6-2 .5-4 2-5 4l-3 .5L9 12l.5-3c2-1 3.5-3 4-5Z"/><path d="M9 15c-1.5.5-2.5 2-2.5 4 2 0 3.5-1 4-2.5M5 19l2-2"/>',
  search: '<circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>',
  target:
    '<circle cx="12" cy="12" r="8"/><circle cx="12" cy="12" r="4"/><circle cx="12" cy="12" r="1"/>',
  spark:
    '<path d="M12 3v4M12 17v4M3 12h4M17 12h4M6 6l2.5 2.5M15.5 15.5 18 18M18 6l-2.5 2.5M8.5 15.5 6 18"/>',
  message:
    '<path d="M4 5h16v11H9l-4 3v-3H4Z"/><path d="M8 9h8M8 12h5"/>',
  megaphone:
    '<path d="m3 11 14-6v14L3 13Z"/><path d="M3 11v2M7 12v5a2 2 0 0 0 3 1"/>',
  cart:
    '<circle cx="9" cy="20" r="1.4"/><circle cx="17" cy="20" r="1.4"/><path d="M3 4h2l2.4 12h10L20 8H6"/>',
  pin: '<path d="M12 21s7-6 7-11a7 7 0 1 0-14 0c0 5 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/>',
  flow:
    '<rect x="3" y="4" width="6" height="5" rx="1"/><rect x="15" y="15" width="6" height="5" rx="1"/><path d="M6 9v4a2 2 0 0 0 2 2h7"/>',
  chart:
    '<path d="M4 20V4"/><path d="M4 20h16"/><rect x="7" y="12" width="3" height="5"/><rect x="12" y="8" width="3" height="9"/><rect x="17" y="5" width="3" height="12"/>',
  card:
    '<rect x="2.5" y="5" width="19" height="14" rx="2"/><path d="M2.5 10h19M6 15h4"/>',
};
const d = paths[name] ?? paths.layout;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={cls}
  aria-hidden="true"
  set:html={d}
/>
