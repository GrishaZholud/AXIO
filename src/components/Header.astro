---
import { site, nav } from '../lib/site';
import { serviceGroups, servicesByGroup } from '../data/services';

interface Props {
  /** Render transparent over a dark hero until the user scrolls */
  transparent?: boolean;
}
const { transparent = false } = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href !== '#' && (href === '/' ? path === '/' : path.startsWith(href));
---

<header
  class="site-header"
  data-header
  data-transparent={transparent ? '' : undefined}
>
  <div class="container site-header__inner">
    <a href="/" class="brand" aria-label="AXIO — на главную">
      <img src="/images/logo.png" alt="AXIO" class="brand__logo brand__logo--dark" width="116" height="41" />
      <img src="/images/logo-light.png" alt="" aria-hidden="true" class="brand__logo brand__logo--light" width="116" height="41" />
    </a>

    <nav class="nav" aria-label="Основная навигация">
      <ul class="nav__list">
        {
          nav.primary.map((item) =>
            item.mega ? (
              <li class="nav__item nav__item--has-mega" data-mega-item>
                <button
                  type="button"
                  class="nav__link nav__trigger"
                  aria-expanded="false"
                  aria-haspopup="true"
                  data-mega-trigger
                >
                  {item.label}
                  <svg width="11" height="11" viewBox="0 0 12 12" aria-hidden="true">
                    <path d="M2.5 4.5 6 8l3.5-3.5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                  </svg>
                </button>
                <div class="mega" data-mega>
                  <div class="mega__grid">
                    {serviceGroups.map((group) => (
                      <div class="mega__col">
                        <p class="mega__title">{group}</p>
                        <ul class="mega__list">
                          {servicesByGroup(group).map((s) => (
                            <li>
                              <a href={`/${s.slug}`} class="mega__link">
                                <span class="mega__link-label">{s.label}</span>
                                <span class="mega__link-desc">{s.short}</span>
                              </a>
                            </li>
                          ))}
                        </ul>
                      </div>
                    ))}
                  </div>
                </div>
              </li>
            ) : (
              <li class="nav__item">
                <a
                  href={item.href}
                  class:list={['nav__link', { 'is-active': isActive(item.href) }]}
                >
                  {item.label}
                </a>
              </li>
            )
          )
        }
      </ul>
    </nav>

    <div class="site-header__actions">
      <a href={`tel:${site.phoneHref}`} class="header-phone">{site.phone}</a>
      <button type="button" class="btn btn--gold btn--sm" data-lead-open>
        Обсудить проект
      </button>
      <button type="button" class="burger" aria-label="Открыть меню" aria-expanded="false" data-burger>
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div class="drawer" data-drawer hidden>
    <nav class="drawer__nav" aria-label="Мобильная навигация">
      <a href="/" class="drawer__link">Главная</a>
      <details class="drawer__group">
        <summary>Услуги</summary>
        {serviceGroups.map((group) => (
          <div class="drawer__subgroup">
            <p class="drawer__subtitle">{group}</p>
            {servicesByGroup(group).map((s) => (
              <a href={`/${s.slug}`} class="drawer__sublink">{s.label}</a>
            ))}
          </div>
        ))}
      </details>
      <a href="/cases" class="drawer__link">Кейсы</a>
      <a href="/about" class="drawer__link">О нас</a>
      <a href="/blog" class="drawer__link">Блог</a>
      <a href="/contacts" class="drawer__link">Контакты</a>
      <button type="button" class="btn btn--gold drawer__cta" data-lead-open>Обсудить проект</button>
      <a href={`tel:${site.phoneHref}`} class="drawer__phone">{site.phone}</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--header-h);
    background: rgba(250, 248, 244, 0.82);
    backdrop-filter: saturate(180%) blur(14px);
    border-bottom: 1px solid var(--line);
    transition: background 0.3s var(--ease), border-color 0.3s var(--ease);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 100%;
  }
  .brand {
    display: inline-flex;
    align-items: center;
  }
  .brand__logo {
    height: 30px;
    width: auto;
    display: block;
  }
  /* Default (solid header / non-hero pages): dark logo */
  .brand__logo--light {
    display: none;
  }

  .nav {
    margin-inline-end: auto;
  }
  .nav__list {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    list-style: none;
    padding: 0;
  }
  .nav__link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.55rem 0.85rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-muted);
    background: none;
    border: 0;
    border-radius: 999px;
    cursor: pointer;
    transition: color 0.2s var(--ease);
  }
  .nav__link:hover,
  .nav__link.is-active {
    color: var(--ink);
  }
  .nav__trigger svg {
    transition: transform 0.25s var(--ease);
  }
  .nav__item--has-mega.is-open .nav__trigger {
    color: var(--ink);
  }
  .nav__item--has-mega.is-open .nav__trigger svg {
    transform: rotate(180deg);
  }

  /* ---- Mega menu ---- */
  .nav__item--has-mega {
    position: static;
  }
  .mega {
    position: absolute;
    left: 50%;
    /* Flush with the header's bottom edge (containing block is the fixed header) */
    top: 100%;
    transform: translateX(-50%) translateY(10px) scale(0.985);
    transform-origin: top center;
    width: min(960px, calc(100vw - 2rem));
    padding: 1.75rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-md);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.26s var(--ease-out), transform 0.32s var(--ease-out),
      visibility 0s linear 0.32s;
  }
  .nav__item--has-mega.is-open .mega {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0) scale(1);
    transition: opacity 0.26s var(--ease-out), transform 0.32s var(--ease-out);
  }
  .mega__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .mega__title {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--gold-deep);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .mega__list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.2rem;
  }
  .mega__link {
    display: block;
    padding: 0.6rem 0.7rem;
    border-radius: var(--radius-sm);
    transition: background 0.18s var(--ease);
  }
  .mega__link:hover {
    background: var(--cream-2);
  }
  .mega__link-label {
    display: block;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--ink);
  }
  .mega__link-desc {
    display: block;
    font-size: 0.82rem;
    color: var(--text-faint);
    margin-top: 0.1rem;
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .header-phone {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--ink);
    white-space: nowrap;
    transition: color 0.3s var(--ease);
  }
  .header-phone:hover {
    color: var(--gold-deep);
  }
  .btn--sm {
    padding: 0.6rem 1.1rem;
    font-size: 0.875rem;
  }

  /* ---- Transparent over dark hero (until scrolled) ---- */
  .site-header[data-transparent]:not(.is-scrolled) {
    background: transparent;
    border-bottom-color: transparent;
    backdrop-filter: none;
  }
  .site-header[data-transparent]:not(.is-scrolled) .header-phone {
    color: var(--on-dark);
  }
  /* Over the dark hero: swap to the light logo */
  .site-header[data-transparent]:not(.is-scrolled) .brand__logo--dark {
    display: none;
  }
  .site-header[data-transparent]:not(.is-scrolled) .brand__logo--light {
    display: block;
  }
  .site-header[data-transparent]:not(.is-scrolled) .nav__link {
    color: var(--on-dark-muted);
  }
  .site-header[data-transparent]:not(.is-scrolled) .nav__link:hover,
  .site-header[data-transparent]:not(.is-scrolled) .nav__link.is-active,
  .site-header[data-transparent]:not(.is-scrolled) .nav__item--has-mega.is-open .nav__trigger {
    color: var(--on-dark);
  }
  .site-header[data-transparent]:not(.is-scrolled) .burger span {
    background: var(--on-dark);
  }

  /* ---- Burger / drawer ---- */
  .burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    background: none;
    border: 0;
    cursor: pointer;
  }
  .burger span {
    display: block;
    height: 2px;
    width: 22px;
    margin-inline: auto;
    background: var(--ink);
    border-radius: 2px;
    transition: transform 0.25s var(--ease), opacity 0.2s var(--ease),
      background 0.3s var(--ease);
  }
  [data-burger][aria-expanded='true'] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  [data-burger][aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }
  [data-burger][aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .drawer {
    position: fixed;
    inset: var(--header-h) 0 0 0;
    background: var(--cream);
    padding: 1.5rem var(--gutter) 3rem;
    overflow-y: auto;
    animation: drawer-in 0.3s var(--ease);
  }
  @keyframes drawer-in {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
  }
  .drawer__nav {
    display: grid;
    gap: 0.25rem;
    max-width: 480px;
  }
  .drawer__link,
  .drawer__group > summary {
    padding: 0.9rem 0.25rem;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--ink);
    border-bottom: 1px solid var(--line);
    cursor: pointer;
    list-style: none;
  }
  .drawer__group > summary::-webkit-details-marker {
    display: none;
  }
  .drawer__group > summary::after {
    content: '+';
    float: right;
    color: var(--gold-deep);
  }
  .drawer__group[open] > summary::after {
    content: '–';
  }
  .drawer__subgroup {
    padding: 0.5rem 0 0.75rem;
  }
  .drawer__subtitle {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--gold-deep);
    font-weight: 700;
    margin: 0.5rem 0;
  }
  .drawer__sublink {
    display: block;
    padding: 0.5rem 0.75rem;
    color: var(--text-muted);
    font-weight: 500;
  }
  .drawer__cta {
    margin-top: 1.5rem;
    width: 100%;
  }
  .drawer__phone {
    margin-top: 1.25rem;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--gold-deep);
    text-align: center;
  }

  @media (max-width: 940px) {
    .nav,
    .header-phone,
    .site-header__actions > .btn {
      display: none;
    }
    .burger {
      display: flex;
    }
    .site-header__inner {
      justify-content: space-between;
    }
  }
</style>

<script>
  // ---- Scroll state: solidify a transparent hero header ----
  const header = document.querySelector<HTMLElement>('[data-header]');
  if (header) {
    const onScroll = () => {
      header.classList.toggle('is-scrolled', window.scrollY > 24);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  // ---- Mega menu with hover-intent (no flicker when crossing the gap) ----
  const megaItem = document.querySelector<HTMLElement>('[data-mega-item]');
  const megaTrigger = document.querySelector<HTMLButtonElement>('[data-mega-trigger]');
  if (megaItem && megaTrigger) {
    let closeTimer: number | undefined;
    const open = () => {
      window.clearTimeout(closeTimer);
      megaItem.classList.add('is-open');
      megaTrigger.setAttribute('aria-expanded', 'true');
    };
    const close = () => {
      megaItem.classList.remove('is-open');
      megaTrigger.setAttribute('aria-expanded', 'false');
    };
    const scheduleClose = () => {
      window.clearTimeout(closeTimer);
      closeTimer = window.setTimeout(close, 180);
    };
    // mouseenter bubbles from the panel too, so re-entering cancels the close
    megaItem.addEventListener('mouseenter', open);
    megaItem.addEventListener('mouseleave', scheduleClose);
    // click / keyboard toggle
    megaTrigger.addEventListener('click', (e) => {
      e.preventDefault();
      megaItem.classList.contains('is-open') ? close() : open();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
    document.addEventListener('click', (e) => {
      if (!megaItem.contains(e.target as Node)) close();
    });
  }

  // ---- Mobile drawer ----
  const burger = document.querySelector<HTMLButtonElement>('[data-burger]');
  const drawer = document.querySelector<HTMLElement>('[data-drawer]');
  if (burger && drawer) {
    const setOpen = (openState: boolean) => {
      burger.setAttribute('aria-expanded', String(openState));
      drawer.hidden = !openState;
      document.body.style.overflow = openState ? 'hidden' : '';
    };
    burger.addEventListener('click', () =>
      setOpen(burger.getAttribute('aria-expanded') !== 'true')
    );
    drawer.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => setOpen(false))
    );
  }
</script>
