---
// Cookie / data-processing notice (РФ 152-ФЗ). The choice (accepted/declined)
// is stored in localStorage so the bar shows once. Rendered once in BaseLayout.
---

<div class="ckbar" data-cookiebar hidden role="region" aria-label="Уведомление о cookie">
  <p class="ckbar__text">
    Мы используем cookie и сервисы аналитики, чтобы сайт работал корректно и был
    удобнее. Нажимая «Принять», вы соглашаетесь на их использование. Подробнее — в
    <a href="/privacy">политике конфиденциальности</a>.
  </p>
  <div class="ckbar__actions">
    <button type="button" class="ckbar__decline" data-cookie-decline>Отклонить</button>
    <button type="button" class="btn btn--gold ckbar__accept" data-cookie-accept>Принять</button>
  </div>
</div>

<style>
  .ckbar {
    position: fixed;
    left: 50%;
    bottom: clamp(1rem, 3vw, 2rem);
    transform: translateX(-50%);
    z-index: 200;
    width: calc(100% - 2rem);
    max-width: 880px;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1rem 1.25rem;
    background: var(--ink);
    color: var(--on-dark-muted);
    border: 1px solid var(--gold-line);
    border-radius: var(--radius);
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.35);
    animation: ckbar-in 0.4s var(--ease) both;
  }
  /* `display: flex` above would otherwise override the [hidden] attribute */
  .ckbar[hidden] {
    display: none;
  }
  @keyframes ckbar-in {
    from {
      opacity: 0;
      transform: translateX(-50%) translateY(16px);
    }
  }
  .ckbar__text {
    font-size: 0.85rem;
    line-height: 1.5;
    margin: 0;
  }
  .ckbar__text a {
    color: var(--gold);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .ckbar__actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-shrink: 0;
  }
  .ckbar__accept {
    padding: 0.6rem 1.4rem;
    font-size: 0.85rem;
  }
  .ckbar__decline {
    padding: 0.6rem 1.1rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--on-dark-muted);
    background: transparent;
    border: 1px solid var(--gold-line);
    border-radius: 999px;
    cursor: pointer;
    transition: color 0.2s var(--ease), border-color 0.2s var(--ease);
  }
  .ckbar__decline:hover {
    color: var(--on-dark);
    border-color: var(--gold);
  }
  @media (max-width: 560px) {
    .ckbar {
      flex-direction: column;
      align-items: stretch;
      text-align: center;
    }
    .ckbar__actions {
      justify-content: center;
    }
  }
</style>

<script>
  const KEY = 'axio-cookie-choice';
  const bar = document.querySelector<HTMLElement>('[data-cookiebar]');
  if (bar && !localStorage.getItem(KEY)) {
    bar.hidden = false;
    const close = (choice: string) => {
      localStorage.setItem(KEY, choice);
      bar.hidden = true;
      // Tell Analytics.astro it may load Metrika now (consent given).
      if (choice === 'accepted') {
        window.dispatchEvent(new Event('axio:cookie-accepted'));
      }
    };
    bar.querySelector('[data-cookie-accept]')?.addEventListener('click', () => close('accepted'));
    bar.querySelector('[data-cookie-decline]')?.addEventListener('click', () => close('declined'));
  }
</script>
