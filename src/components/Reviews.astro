---
import { reviews } from '../data/reviews';
export interface Props {
  title?: string;
  eyebrow?: string;
  dark?: boolean;
}
const { title = 'Что говорят клиенты', eyebrow = 'Отзывы', dark = false } = Astro.props;
---

<section
  class="reviews section"
  data-theme={dark ? 'dark' : undefined}
  aria-labelledby="reviews-title"
>
  <div class="container">
    <div class="section-head section-head--center reveal">
      <span class="eyebrow">{eyebrow}</span>
      <h2 class="h2" id="reviews-title">{title}</h2>
    </div>
    <ul class="reviews__grid reveal">
      {
        reviews.map((r) => (
          <li class="review">
            <div class="review__stars" aria-label="Оценка 5 из 5">
              {[0, 1, 2, 3, 4].map(() => (
                <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
                  <path d="M8 1.5l1.9 3.9 4.3.6-3.1 3 .7 4.3L8 11.3 4.2 13.3l.7-4.3-3.1-3 4.3-.6z" fill="currentColor" />
                </svg>
              ))}
            </div>
            <blockquote class="review__text">{r.text}</blockquote>
            <div class="review__author">
              <span class="review__name">{r.author}</span>
              <span class="review__role">{r.role}</span>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .reviews__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
    list-style: none;
    padding: 0;
  }
  .review {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.75rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .review__stars {
    display: flex;
    gap: 2px;
    color: var(--gold);
  }
  .review__text {
    margin: 0;
    color: var(--fg);
    line-height: 1.6;
    font-size: 0.96rem;
    flex: 1;
  }
  .review__author {
    display: grid;
    gap: 0.15rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }
  .review__name {
    font-weight: 700;
    color: var(--fg);
  }
  .review__role {
    font-size: 0.85rem;
    color: var(--fg-muted);
  }
</style>
