---
// Service-page hero background: warm dark cover with a faint grid, gold glow,
// corner ticks and a gold "chip" plaque holding a per-service line motif on the
// right (text sits on the left). Live CSS/SVG — crisp at any size, responsive.
// Design ported from the AXIO "обложки направлений" reference.
export interface Props {
  /** service slug — selects the motif */
  motif: string;
}
const { motif } = Astro.props;

// viewBox 0 0 120 120, gold stroke. Motifs from the reference (+ a new `ai`).
const motifs: Record<string, string> = {
  tilda: `<rect x="26" y="30" width="68" height="15" rx="5"/><rect x="26" y="53" width="46" height="15" rx="5"/><rect x="26" y="76" width="58" height="15" rx="5"/><circle cx="94" cy="60.5" r="3.4" fill="#f0d9af" stroke="none"/><circle cx="80" cy="83.5" r="3.4" fill="#f0d9af" stroke="none"/>`,
  code: `<polyline points="42,40 24,60 42,80"/><polyline points="78,40 96,60 78,80"/><line x1="68" y1="34" x2="52" y2="86"/>`,
  template: `<rect x="28" y="28" width="28" height="28" rx="5"/><rect x="64" y="28" width="28" height="28" rx="5"/><rect x="28" y="64" width="28" height="28" rx="5"/><rect x="64" y="64" width="28" height="28" rx="5" fill="rgba(231,205,160,0.18)"/>`,
  seo: `<rect x="28" y="66" width="9" height="20" rx="2.5"/><rect x="43" y="54" width="9" height="32" rx="2.5"/><rect x="58" y="42" width="9" height="44" rx="2.5"/><circle cx="79" cy="46" r="17"/><line x1="91" y1="58" x2="100" y2="67"/>`,
  target: `<circle cx="60" cy="60" r="30"/><circle cx="60" cy="60" r="17"/><circle cx="60" cy="60" r="5" fill="#f0d9af" stroke="none"/><line x1="60" y1="14" x2="60" y2="24"/><line x1="60" y1="96" x2="60" y2="106"/><line x1="14" y1="60" x2="24" y2="60"/><line x1="96" y1="60" x2="106" y2="60"/>`,
  ai: `<circle cx="60" cy="60" r="29"/><path d="M60 38 l4.5 13 13 4.5 -13 4.5 -4.5 13 -4.5 -13 -13 -4.5 13 -4.5 z" fill="#f0d9af" stroke="none"/><circle cx="60" cy="20" r="3" fill="#f0d9af" stroke="none"/><circle cx="100" cy="60" r="3" fill="#f0d9af" stroke="none"/><circle cx="60" cy="100" r="3" fill="#f0d9af" stroke="none"/><circle cx="20" cy="60" r="3" fill="#f0d9af" stroke="none"/>`,
  aeo: `<path d="M28 38 h52 a9 9 0 0 1 9 9 v22 a9 9 0 0 1 -9 9 H56 l-13 13 v-13 H28 a9 9 0 0 1 -9 -9 V47 a9 9 0 0 1 9 -9 Z"/><path d="M40 68 l8 -20 l8 20"/><line x1="43.5" y1="61" x2="52.5" y2="61"/><path d="M80 30 l3 7 7 3 -7 3 -3 7 -3 -7 -7 -3 7 -3 z" fill="#f0d9af" stroke="none"/>`,
  chatgptads: `<path d="M26 34 h68 a9 9 0 0 1 9 9 v26 a9 9 0 0 1 -9 9 H58 l-14 13 v-13 H26 a9 9 0 0 1 -9 -9 V43 a9 9 0 0 1 9 -9 Z"/><path d="M54 42 C56.5 53.5 60 57 71.5 59.5 C60 62 56.5 65.5 54 77 C51.5 65.5 48 62 36.5 59.5 C48 57 51.5 53.5 54 42 Z" fill="#f0d9af" stroke="none"/><path d="M80 44 l2.4 5.6 5.6 2.4 -5.6 2.4 -2.4 5.6 -2.4 -5.6 -5.6 -2.4 5.6 -2.4 z" fill="#f0d9af" stroke="none"/>`,
  marketplaces: `<path d="M30 50 l6 -18 h48 l6 18"/><path d="M30 50 v40 h60 v-40"/><path d="M30 50 q0 9 9 9 t9 -9 q0 9 9 9 t9 -9 q0 9 9 9 t9 -9 q0 9 9 9 t9 -9"/><rect x="52" y="68" width="16" height="22" rx="2"/>`,
  maps: `<path d="M60 26 a22 22 0 0 1 22 22 c0 17 -22 44 -22 44 s-22 -27 -22 -44 a22 22 0 0 1 22 -22 z"/><circle cx="60" cy="48" r="7.5" fill="#f0d9af" stroke="none"/>`,
  crm: `<circle cx="60" cy="32" r="9"/><circle cx="32" cy="82" r="9"/><circle cx="88" cy="82" r="9"/><line x1="55" y1="40" x2="37" y2="74"/><line x1="65" y1="40" x2="83" y2="74"/><line x1="41" y1="82" x2="79" y2="82"/><circle cx="60" cy="32" r="3" fill="#f0d9af" stroke="none"/><circle cx="32" cy="82" r="3" fill="#f0d9af" stroke="none"/><circle cx="88" cy="82" r="3" fill="#f0d9af" stroke="none"/>`,
};
const inner = motifs[motif] ?? motifs.seo;
---

<div class="shb" aria-hidden="true">
  <div class="shb__grid"></div>
  <div class="shb__glow"></div>
  <div class="shb__vig"></div>
  <span class="shb__tick tl"></span>
  <span class="shb__tick tr"></span>
  <span class="shb__tick bl"></span>
  <span class="shb__tick br"></span>
  <div class="shb__plaque">
    <div class="shb__pglow"></div>
    <div class="shb__pbox">
      <svg
        class="shb__motif"
        viewBox="0 0 120 120"
        fill="none"
        stroke="#e7cda0"
        stroke-width="3"
        stroke-linecap="round"
        stroke-linejoin="round"
        set:html={inner}
      />
    </div>
    <span class="shb__pin v" style="top:-7px;left:34px"></span>
    <span class="shb__pin v" style="top:-7px;right:34px"></span>
    <span class="shb__pin v" style="bottom:-7px;left:34px"></span>
    <span class="shb__pin v" style="bottom:-7px;right:34px"></span>
    <span class="shb__pin h" style="left:-7px;top:34px"></span>
    <span class="shb__pin h" style="left:-7px;bottom:34px"></span>
    <span class="shb__pin h" style="right:-7px;top:34px"></span>
    <span class="shb__pin h" style="right:-7px;bottom:34px"></span>
  </div>
</div>

<style>
  .shb {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    background: radial-gradient(120% 120% at 50% 32%, #241b10 0%, #15110b 46%, #0a0705 100%);
  }
  .shb__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(206, 170, 118, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(206, 170, 118, 0.05) 1px, transparent 1px);
    background-size: 48px 48px;
    -webkit-mask-image: radial-gradient(58% 80% at 80% 50%, #000, transparent 80%);
    mask-image: radial-gradient(58% 80% at 80% 50%, #000, transparent 80%);
  }
  .shb__glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(38% 52% at 80% 50%, rgba(214, 176, 120, 0.22), transparent 62%);
  }
  .shb__vig {
    position: absolute;
    inset: 0;
    background: radial-gradient(125% 110% at 50% 42%, transparent 42%, rgba(0, 0, 0, 0.55) 100%);
  }

  .shb__tick {
    position: absolute;
    width: 26px;
    height: 26px;
  }
  .shb__tick.tl {
    top: 28px;
    left: 28px;
    border-top: 1.5px solid rgba(206, 170, 118, 0.38);
    border-left: 1.5px solid rgba(206, 170, 118, 0.38);
  }
  .shb__tick.tr {
    top: 28px;
    right: 28px;
    border-top: 1.5px solid rgba(206, 170, 118, 0.38);
    border-right: 1.5px solid rgba(206, 170, 118, 0.38);
  }
  .shb__tick.bl {
    bottom: 28px;
    left: 28px;
    border-bottom: 1.5px solid rgba(206, 170, 118, 0.38);
    border-left: 1.5px solid rgba(206, 170, 118, 0.38);
  }
  .shb__tick.br {
    bottom: 28px;
    right: 28px;
    border-bottom: 1.5px solid rgba(206, 170, 118, 0.38);
    border-right: 1.5px solid rgba(206, 170, 118, 0.38);
  }

  .shb__plaque {
    position: absolute;
    top: 50%;
    right: clamp(3rem, 9vw, 8.5rem);
    transform: translateY(-50%);
    width: clamp(160px, 15vw, 210px);
    aspect-ratio: 1;
  }
  .shb__pglow {
    position: absolute;
    inset: -34px;
    background: radial-gradient(circle, rgba(214, 176, 120, 0.3), transparent 66%);
  }
  .shb__pbox {
    position: absolute;
    inset: 0;
    border-radius: 16%;
    background: linear-gradient(160deg, rgba(42, 32, 19, 0.92), rgba(18, 13, 8, 0.94));
    border: 1.5px solid rgba(206, 170, 118, 0.5);
    box-shadow: inset 0 0 44px rgba(214, 176, 120, 0.14), 0 22px 54px rgba(0, 0, 0, 0.55);
    display: grid;
    place-items: center;
  }
  .shb__motif {
    width: 57%;
    height: 57%;
    filter: drop-shadow(0 0 12px rgba(214, 176, 120, 0.55));
  }
  .shb__pin {
    position: absolute;
    background: rgba(206, 170, 118, 0.55);
  }
  .shb__pin.v {
    width: 1.5px;
    height: 14px;
  }
  .shb__pin.h {
    height: 1.5px;
    width: 14px;
  }

  /* Hide the chip where it would crowd the hero text; keep the warm bg + glow */
  @media (max-width: 1080px) {
    .shb__plaque {
      display: none;
    }
    .shb__grid {
      -webkit-mask-image: radial-gradient(70% 70% at 60% 36%, #000, transparent 80%);
      mask-image: radial-gradient(70% 70% at 60% 36%, #000, transparent 80%);
    }
    .shb__glow {
      background: radial-gradient(55% 55% at 58% 32%, rgba(214, 176, 120, 0.18), transparent 62%);
    }
  }
  @media (max-width: 600px) {
    .shb__tick {
      display: none;
    }
  }
</style>
