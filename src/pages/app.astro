<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="robots" content="noindex, nofollow">
<title>AXIO CRM</title>
<style is:inline>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#080808;--surface:#111;--card:#181818;--border:#252525;
  --accent:#c8ff00;--text:#f0f0f0;--muted:#666;--dim:#2a2a2a;
  --red:#ff4444;--orange:#ffaa00;--blue:#4488ff;--green:#00cc66;--purple:#aa66ff;
}
body{font-family:-apple-system,BlinkMacSystemFont,'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow:hidden}
/* LOGIN */
#login{position:fixed;inset:0;background:var(--bg);display:flex;align-items:center;justify-content:center;z-index:999}
.login-box{width:380px;padding:48px;background:var(--surface);border:1px solid var(--border);border-radius:16px}
.login-logo{font-size:32px;font-weight:900;color:var(--accent);letter-spacing:-1px;margin-bottom:4px}
.login-sub{color:var(--muted);font-size:13px;margin-bottom:36px}
.login-box input{width:100%;padding:13px 16px;background:var(--card);border:1px solid var(--border);border-radius:8px;color:var(--text);font-size:15px;outline:none;margin-bottom:12px;transition:border-color .2s}
.login-box input:focus{border-color:var(--accent)}
.login-box button{width:100%;padding:13px;background:var(--accent);color:#000;border:none;border-radius:8px;font-size:15px;font-weight:800;cursor:pointer;transition:opacity .2s}
.login-box button:hover{opacity:.88}
.login-err{color:var(--red);font-size:13px;margin-top:10px;display:none;text-align:center}
/* HEADER */
header{height:58px;background:rgba(8,8,8,.96);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 24px;flex-shrink:0}
.logo{font-size:20px;font-weight:900;color:var(--accent);letter-spacing:-0.5px}
.header-center{display:flex;gap:4px}
.tab-btn{padding:7px 18px;background:transparent;border:1px solid transparent;border-radius:7px;color:var(--muted);font-size:13px;font-weight:600;cursor:pointer;transition:.2s}
.tab-btn.active{background:var(--surface);border-color:var(--border);color:var(--text)}
.tab-btn:hover:not(.active){color:var(--text)}
.header-right{display:flex;align-items:center;gap:16px}
.stats{display:flex;gap:20px}
.stat-val{font-size:17px;font-weight:800;color:var(--accent);line-height:1}
.stat-lbl{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px}
.sync-dot{width:8px;height:8px;border-radius:50%;background:var(--green);box-shadow:0 0 6px var(--green);flex-shrink:0}
.sync-dot.off{background:var(--red);box-shadow:0 0 6px var(--red)}
.btn-new{padding:8px 18px;background:var(--accent);color:#000;border:none;border-radius:7px;font-size:13px;font-weight:800;cursor:pointer;transition:opacity .2s;white-space:nowrap}
.btn-new:hover{opacity:.85}
/* APP LAYOUT */
#app{display:none;flex-direction:column;height:100vh}
/* ─── CRM TAB ─── */
#tab-crm{flex:1;overflow:hidden;display:flex;flex-direction:column;min-height:0}
.board-wrap{padding:20px;overflow-x:auto;overflow-y:hidden;flex:1;display:flex;flex-direction:column;min-height:0}
.board{display:flex;gap:14px;flex:1;min-width:max-content;min-height:0;align-items:stretch}
/* COLUMN */
.col{width:270px;flex-shrink:0;background:var(--surface);border:1px solid var(--border);border-radius:12px;display:flex;flex-direction:column;overflow:hidden;min-height:0}
.col-head{padding:13px 16px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border);flex-shrink:0}
.col-title{display:flex;align-items:center;gap:8px;font-size:13px;font-weight:700}
.dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.col-new      .dot{background:var(--muted)}
.col-missed   .dot{background:var(--orange)}
.col-postpone .dot{background:var(--purple)}
.col-feedback .dot{background:#4fc3f7}
.col-negotion .dot{background:var(--blue)}
.col-warm     .dot{background:#66bb6a}
.col-done     .dot{background:var(--green)}
.col-refuse   .dot{background:var(--red)}
.col-cnt{font-size:12px;color:var(--muted);background:var(--card);padding:2px 9px;border-radius:20px;min-width:28px;text-align:center}
.col-body{flex:1;padding:8px;display:flex;flex-direction:column;gap:7px;overflow-y:auto;overflow-x:hidden;transition:background .15s}
.col-body.over{background:rgba(200,255,0,.04)}
/* CARD */
.card{background:var(--card);border:1px solid var(--border);border-radius:9px;padding:12px;cursor:pointer;transition:border-color .2s,transform .15s;position:relative;user-select:none}
.card:hover{border-color:#333;transform:translateY(-1px)}
.card.dragging{opacity:.35;cursor:grabbing}
.card-top{display:flex;align-items:flex-start;justify-content:space-between;gap:6px}
.card-company{font-size:13px;font-weight:700;line-height:1.3;flex:1}
.card-actions{display:flex;gap:3px;opacity:0;transition:opacity .2s;flex-shrink:0}
.card:hover .card-actions{opacity:1}
.cbtn{width:24px;height:24px;border:none;border-radius:5px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:12px;transition:background .2s}
.cbtn-e{background:rgba(255,255,255,.07);color:var(--text)}
.cbtn-e:hover{background:rgba(255,255,255,.14)}
.cbtn-d{background:rgba(255,68,68,.12);color:var(--red)}
.cbtn-d:hover{background:rgba(255,68,68,.28)}
.card-meta{display:flex;flex-direction:column;gap:4px;margin-top:8px}
.card-row{display:flex;align-items:center;gap:6px;font-size:11px;color:var(--muted)}
.card-row a{color:var(--muted);text-decoration:none;transition:color .15s}
.card-row a:hover{color:var(--accent)}
.ico{font-style:normal;font-size:10px;flex-shrink:0;width:13px;text-align:center;opacity:.7}
.card-note{margin-top:8px;padding-top:8px;border-top:1px solid var(--dim);font-size:11px;color:var(--muted);font-style:italic;line-height:1.4}
.card-next{margin-top:8px;display:flex;align-items:center;gap:5px;font-size:11px;font-weight:600;color:var(--accent)}
.card-next.overdue{color:var(--red)}
.card-next.today{color:var(--orange)}
.empty{text-align:center;padding:36px 14px;color:var(--dim);font-size:12px;line-height:1.7}
/* ─── ЗАДАЧНИК TAB ─── */
#tab-tasks{flex:1;overflow-x:auto;overflow-y:hidden;padding:20px;display:none;min-height:0}
.tasks-grid{display:flex;gap:14px;min-width:max-content;height:100%;align-items:stretch}
.task-section{background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden;width:290px;flex-shrink:0;display:flex;flex-direction:column;min-height:0}
.task-section-head{padding:14px 16px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border);flex-shrink:0}
.task-section-title{font-size:13px;font-weight:700;display:flex;align-items:center;gap:8px}
.ts-dot{width:8px;height:8px;border-radius:50%}
.ts-overdue  .ts-dot{background:var(--red)}
.ts-today    .ts-dot{background:var(--orange)}
.ts-tomorrow .ts-dot{background:var(--blue)}
.ts-week     .ts-dot{background:var(--purple)}
.ts-month    .ts-dot{background:var(--green)}
.ts-later    .ts-dot{background:var(--muted)}
.task-section-cnt{font-size:12px;color:var(--muted);background:var(--card);padding:2px 9px;border-radius:20px}
.task-list{padding:8px;display:flex;flex-direction:column;gap:7px;overflow-y:auto;flex:1;min-height:0}
.task-item{background:var(--card);border:1px solid var(--border);border-radius:9px;padding:12px;cursor:pointer;transition:border-color .2s,transform .15s}
.task-item:hover{border-color:#333;transform:translateY(-1px)}
.task-item-top{display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:6px}
.task-company{font-size:13px;font-weight:700}
.task-time{font-size:11px;font-weight:700;padding:3px 8px;border-radius:5px;white-space:nowrap;flex-shrink:0}
.ts-overdue  .task-time{background:rgba(255,68,68,.15);color:var(--red)}
.ts-today    .task-time{background:rgba(255,170,0,.15);color:var(--orange)}
.ts-tomorrow .task-time{background:rgba(68,136,255,.15);color:var(--blue)}
.ts-week     .task-time{background:rgba(170,102,255,.15);color:var(--purple)}
.ts-month    .task-time{background:rgba(0,204,102,.15);color:var(--green)}
.ts-later    .task-time{background:rgba(102,102,102,.15);color:var(--muted)}
.task-col-badge{font-size:11px;color:var(--muted);display:flex;align-items:center;gap:5px}
.task-note{margin-top:6px;font-size:11px;color:var(--muted);font-style:italic}
.task-empty{padding:20px;text-align:center;color:var(--dim);font-size:12px}
/* VIEW MODAL */
.view-overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:500;display:none;align-items:center;justify-content:center;padding:20px}
.view-overlay.on{display:flex}
.view-modal{background:var(--surface);border:1px solid var(--border);border-radius:14px;width:100%;max-width:480px;overflow:hidden}
.view-header{padding:24px 24px 0;display:flex;align-items:flex-start;justify-content:space-between;gap:12px}
.view-company{font-size:20px;font-weight:800;line-height:1.2;flex:1}
.view-close{width:32px;height:32px;border:none;background:rgba(255,255,255,.07);border-radius:7px;color:var(--muted);font-size:16px;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:background .2s}
.view-close:hover{background:rgba(255,255,255,.14);color:var(--text)}
.view-sphere{margin:8px 24px 0;display:inline-block;font-size:11px;color:var(--muted);background:rgba(255,255,255,.06);padding:3px 10px;border-radius:4px}
.view-fields{padding:20px 24px;display:flex;flex-direction:column;gap:10px}
.vf{display:flex;align-items:flex-start;gap:10px;font-size:13px}
.vf-ico{font-style:normal;font-size:14px;flex-shrink:0;width:20px;text-align:center;margin-top:1px}
.vf-label{color:var(--muted);font-size:11px;margin-bottom:2px;text-transform:uppercase;letter-spacing:.4px}
.vf-val{color:var(--text);line-height:1.4}
.vf-val a{color:var(--accent);text-decoration:none}
.vf-val a:hover{text-decoration:underline}
.view-note{margin:0 24px;padding:14px;background:rgba(255,255,255,.04);border-radius:8px;font-size:13px;color:var(--muted);font-style:italic;line-height:1.5;border-left:2px solid var(--dim)}
.view-actions{padding:20px 24px;display:flex;gap:10px;border-top:1px solid var(--border);margin-top:20px}
.btn-view-edit{flex:1;padding:10px;background:var(--accent);color:#000;border:none;border-radius:7px;font-size:14px;font-weight:800;cursor:pointer;transition:opacity .2s}
.btn-view-edit:hover{opacity:.85}
.btn-view-del{padding:10px 16px;background:rgba(255,68,68,.12);color:var(--red);border:1px solid rgba(255,68,68,.2);border-radius:7px;font-size:14px;cursor:pointer;transition:.2s}
.btn-view-del:hover{background:rgba(255,68,68,.25)}
/* EDIT MODAL */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:600;display:none;align-items:center;justify-content:center;padding:20px}
.overlay.on{display:flex}
.modal{background:var(--surface);border:1px solid var(--border);border-radius:14px;width:100%;max-width:560px;max-height:90vh;overflow-y:auto;padding:32px}
.modal-title{font-size:18px;font-weight:800;margin-bottom:24px}
.fgrid{display:grid;grid-template-columns:1fr 1fr;gap:13px}
.full{grid-column:span 2}
.fg{display:flex;flex-direction:column;gap:6px}
.fg label{font-size:11px;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:.6px}
.fg input,.fg select,.fg textarea{padding:10px 13px;background:var(--card);border:1px solid var(--border);border-radius:7px;color:var(--text);font-size:14px;outline:none;transition:border-color .2s;font-family:inherit;width:100%}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--accent)}
.fg select option{background:var(--card)}
.fg textarea{resize:vertical;min-height:72px}
.modal-btns{display:flex;gap:10px;margin-top:22px;justify-content:flex-end}
.btn-cancel{padding:10px 20px;background:transparent;border:1px solid var(--border);border-radius:7px;color:var(--muted);font-size:14px;cursor:pointer;transition:.2s}
.btn-cancel:hover{border-color:#444;color:var(--text)}
.btn-save{padding:10px 26px;background:var(--accent);color:#000;border:none;border-radius:7px;font-size:14px;font-weight:800;cursor:pointer;transition:opacity .2s}
.btn-save:hover{opacity:.85}
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:#2a2a2a;border-radius:3px}
</style>
</head>
<body>
<!-- LOGIN -->
<div id="login">
  <div class="login-box">
    <div class="login-logo">AXIO</div>
    <div class="login-sub">CRM — Система управления клиентами</div>
    <input type="email" id="email" placeholder="Email" onkeydown="if(event.key==='Enter')doLogin()">
    <input type="password" id="pwd" placeholder="Пароль" onkeydown="if(event.key==='Enter')doLogin()">
    <button onclick="doLogin()">Войти</button>
    <div class="login-err" id="lerr">Неверный email или пароль</div>
  </div>
</div>
<!-- APP -->
<div id="app">
  <header>
    <div class="logo">AXIO CRM</div>
    <div class="header-center">
      <button class="tab-btn active" id="btn-crm" onclick="switchTab('crm')">📋 CRM</button>
      <button class="tab-btn" id="btn-tasks" onclick="switchTab('tasks')">📅 Задачник</button>
    </div>
    <div class="header-right">
      <div class="stats">
        <div><div class="stat-val" id="s-total">0</div><div class="stat-lbl">Всего</div></div>
        <div><div class="stat-val" id="s-warm">0</div><div class="stat-lbl">Тёплых</div></div>
        <div><div class="stat-val" id="s-done">0</div><div class="stat-lbl">Сделок</div></div>
      </div>
      <div class="sync-dot" id="sync-dot"></div>
      <button class="btn-new" onclick="openModal()">+ Добавить</button>
    </div>
  </header>
  <!-- CRM TAB -->
  <div id="tab-crm">
    <div class="board-wrap">
      <div class="board" id="board">
        <div class="col col-new">
          <div class="col-head"><div class="col-title"><span class="dot"></span>Необработанные</div><span class="col-cnt" id="cnt-new">0</span></div>
          <div class="col-body" id="body-new" ondragover="onDragOver(event)" ondrop="onDrop(event,'new')" ondragleave="onDragLeave(event)"></div>
        </div>
        <div class="col col-missed">
          <div class="col-head"><div class="col-title"><span class="dot"></span>Недозвон</div><span class="col-cnt" id="cnt-missed">0</span></div>
          <div class="col-body" id="body-missed" ondragover="onDragOver(event)" ondrop="onDrop(event,'missed')" ondragleave="onDragLeave(event)"></div>
        </div>
        <div class="col col-postpone">
          <div class="col-head"><div class="col-title"><span class="dot"></span>Перенос сроков</div><span class="col-cnt" id="cnt-postpone">0</span></div>
          <div class="col-body" id="body-postpone" ondragover="onDragOver(event)" ondrop="onDrop(event,'postpone')" ondragleave="onDragLeave(event)"></div>
        </div>
        <div class="col col-feedback">
          <div class="col-head"><div class="col-title"><span class="dot"></span>Получить обратную связь</div><span class="col-cnt" id="cnt-feedback">0</span></div>
          <div class="col-body" id="body-feedback" ondragover="onDragOver(event)" ondrop="onDrop(event,'feedback')" ondragleave="onDragLeave(event)"></div>
        </div>
        <div class="col col-negotion">
          <div class="col-head"><div class="col-title"><span class="dot"></span>Согласование</div><span class="col-cnt" id="cnt-negotion">0</span></div>
          <div class="col-body" id="body-negotion" ondragover="onDragOver(event)" ondrop="onDrop(event,'negotion')" ondragleave="onDragLeave(event)"></div>
        </div>
        <div class="col col-warm">
          <div class="col-head"><div class="col-title"><span class="dot"></span>Тёплые клиенты</div><span class="col-cnt" id="cnt-warm">0</span></div>
          <div class="col-body" id="body-warm" ondragover="onDragOver(event)" ondrop="onDrop(event,'warm')" ondragleave="onDragLeave(event)"></div>
        </div>
        <div class="col col-done">
          <div class="col-head"><div class="col-title"><span class="dot"></span>Состоявшиеся сделки</div><span class="col-cnt" id="cnt-done">0</span></div>
          <div class="col-body" id="body-done" ondragover="onDragOver(event)" ondrop="onDrop(event,'done')" ondragleave="onDragLeave(event)"></div>
        </div>
        <div class="col col-refuse">
          <div class="col-head"><div class="col-title"><span class="dot"></span>Отказ</div><span class="col-cnt" id="cnt-refuse">0</span></div>
          <div class="col-body" id="body-refuse" ondragover="onDragOver(event)" ondrop="onDrop(event,'refuse')" ondragleave="onDragLeave(event)"></div>
        </div>
      </div>
    </div>
  </div>
  <!-- ЗАДАЧНИК TAB -->
  <div id="tab-tasks">
    <div class="tasks-grid" id="tasks-grid"></div>
  </div>
</div>
<!-- VIEW CARD -->
<div class="view-overlay" id="view-overlay" onclick="closeView(event)">
  <div class="view-modal" onclick="event.stopPropagation()">
    <div class="view-header">
      <div class="view-company" id="v-company"></div>
      <button class="view-close" onclick="closeViewDirect()">✕</button>
    </div>
    <div id="v-sphere"></div>
    <div class="view-fields" id="v-fields"></div>
    <div id="v-note"></div>
    <div class="view-actions">
      <button class="btn-view-edit" id="v-edit-btn">✎ Редактировать</button>
      <button class="btn-view-del" id="v-del-btn">Удалить</button>
    </div>
  </div>
</div>
<!-- EDIT MODAL -->
<div class="overlay" id="overlay" onclick="closeModal(event)">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-title" id="modal-title">Новый клиент</div>
    <div class="fgrid">
      <div class="fg full"><label>Название компании *</label><input id="f-company" placeholder="ООО Ромашка" type="text"></div>
      <div class="fg"><label>Телефон</label><input id="f-phone" placeholder="+7 999 000 00 00" type="text"></div>
      <div class="fg"><label>Сфера деятельности</label><input id="f-sphere" placeholder="Строительство" type="text"></div>
      <div class="fg full"><label>Адрес</label><input id="f-address" placeholder="Екатеринбург, ул. Ленина 1" type="text"></div>
      <div class="fg"><label>Время от Екатеринбурга</label><input id="f-timezone" placeholder="+0 (МСК-2)" type="text"></div>
      <div class="fg"><label>Сайт</label><input id="f-site" placeholder="https://example.ru" type="text"></div>
      <div class="fg"><label>Статус сайта</label>
        <select id="f-site-status">
          <option value="">— не указано —</option>
          <option value="yes">Есть, современный</option>
          <option value="old">Есть, устаревший</option>
          <option value="no">Нет сайта</option>
        </select>
      </div>
      <div class="fg"><label>Ссылка 2ГИС</label><input id="f-gis" placeholder="https://2gis.ru/..." type="text"></div>
      <div class="fg"><label>Следующий контакт — дата</label><input id="f-next-date" type="date"></div>
      <div class="fg"><label>Следующий контакт — время</label><input id="f-next-time" type="time" value="10:00"></div>
      <div class="fg"><label>Статус клиента</label>
        <select id="f-col">
          <option value="new">Необработанные</option>
          <option value="missed">Недозвон</option>
          <option value="postpone">Перенос сроков</option>
          <option value="feedback">Получить обратную связь</option>
          <option value="negotion">Согласование</option>
          <option value="warm">Тёплые клиенты</option>
          <option value="done">Состоявшиеся сделки</option>
          <option value="refuse">Отказ</option>
        </select>
      </div>
      <div class="fg full"><label>Примечание</label><textarea id="f-note" placeholder="Заметки о клиенте..."></textarea></div>
    </div>
    <div class="modal-btns">
      <button class="btn-cancel" onclick="closeModalDirect()">Отмена</button>
      <button class="btn-save" onclick="saveCard()">Сохранить</button>
    </div>
  </div>
</div>
<script type="module" is:inline>
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getFirestore, collection, onSnapshot, doc, setDoc, deleteDoc } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";
import { getAuth, signInWithEmailAndPassword, signOut, onAuthStateChanged, setPersistence, browserSessionPersistence } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";

const firebaseConfig = {
  apiKey: "AIzaSyA9vTeDfI9PqZRCrPw8cr_Kso32JT_mzSk",
  authDomain: "axio-crm.firebaseapp.com",
  projectId: "axio-crm",
  storageBucket: "axio-crm.firebasestorage.app",
  messagingSenderId: "156479167366",
  appId: "1:156479167366:web:6acf4608797dbfdca62a07"
};

const app    = initializeApp(firebaseConfig);
const db     = getFirestore(app);
const auth   = getAuth(app);
const colRef = collection(db, 'cards');

let cards  = [];
let editId = null;
let dragId = null;

const SESSION_DURATION = 60 * 60 * 1000; // 1 час
let sessionTimer = null;

// ── Парсим дату/время как Екатеринбург UTC+5 ──
function parseEkbDateTime(date, time) {
  if (!date) return null;
  const timeStr = time || '23:59';
  return new Date(date + 'T' + timeStr + ':00+05:00');
}

function showApp(){
  document.getElementById('login').style.display = 'none';
  document.getElementById('app').style.display   = 'flex';
  startSync();
  startSessionTimer();
  // Обновляем каждую минуту — задачи уходят в просроченные точно по времени
  setInterval(() => {
    renderCRM();
    if(document.getElementById('tab-tasks').style.display !== 'none') renderTasks();
  }, 60000);
}

function forceLogout(){
  clearTimeout(sessionTimer);
  sessionStorage.removeItem('loginTime');
  signOut(auth);
  document.getElementById('app').style.display   = 'none';
  document.getElementById('login').style.display = 'flex';
  document.getElementById('email').value = '';
  document.getElementById('pwd').value   = '';
}

function startSessionTimer(){
  clearTimeout(sessionTimer);
  const loginTime = parseInt(sessionStorage.getItem('loginTime') || '0');
  const elapsed   = Date.now() - loginTime;
  const remaining = SESSION_DURATION - elapsed;
  if(remaining <= 0){ forceLogout(); return; }
  sessionTimer = setTimeout(() => {
    forceLogout();
    alert('Сессия истекла. Пожалуйста, войдите снова.');
  }, remaining);
}

onAuthStateChanged(auth, user => {
  if(!user) return;
  const loginTime = parseInt(sessionStorage.getItem('loginTime') || '0');
  const elapsed   = Date.now() - loginTime;
  if(loginTime && elapsed < SESSION_DURATION){
    showApp();
  } else {
    forceLogout();
  }
});

const COLS = ['new','missed','postpone','feedback','negotion','warm','done','refuse'];
const COL_LABELS = {
  new:'Необработанные', missed:'Недозвон', postpone:'Перенос сроков',
  feedback:'Получить обратную связь', negotion:'Согласование',
  warm:'Тёплые клиенты', done:'Состоявшиеся сделки', refuse:'Отказ'
};
const STATUS_LABELS = {yes:'Есть (современный)', old:'Есть (устаревший)', no:'Нет сайта'};

// ── AUTH ──
window.doLogin = async () => {
  const email = document.getElementById('email').value.trim();
  const pwd   = document.getElementById('pwd').value;
  const err   = document.getElementById('lerr');
  err.style.display = 'none';
  try {
    await setPersistence(auth, browserSessionPersistence);
    await signInWithEmailAndPassword(auth, email, pwd);
    sessionStorage.setItem('loginTime', Date.now().toString());
    showApp();
  } catch(e) {
    err.style.display = 'block';
    document.getElementById('pwd').value = '';
  }
};

// ── TABS ──
window.switchTab = (tab) => {
  document.getElementById('tab-crm').style.display   = tab==='crm'   ? 'flex' : 'none';
  document.getElementById('tab-tasks').style.display = tab==='tasks' ? 'flex' : 'none';
  document.getElementById('btn-crm').classList.toggle('active',   tab==='crm');
  document.getElementById('btn-tasks').classList.toggle('active', tab==='tasks');
  if(tab==='tasks') renderTasks();
};

// ── SYNC ──
function startSync(){
  const dot = document.getElementById('sync-dot');
  onSnapshot(colRef, snap => {
    cards = snap.docs.map(d => ({id:d.id, ...d.data()}));
    dot.classList.remove('off');
    renderCRM();
    if(document.getElementById('tab-tasks').style.display !== 'none') renderTasks();
  }, () => dot.classList.add('off'));
}

// ── NEXT CONTACT LABEL (с точным временем, Екатеринбург UTC+5) ──
function nextLabel(c){
  if(!c.nextDate) return null;
  const now  = new Date();
  const next = parseEkbDateTime(c.nextDate, c.nextTime);
  const diffMs = next - now;
  const time   = c.nextTime || '';

  if(diffMs < 0){
    // Просрочено — считаем сколько дней
    const overdueDays = Math.ceil(Math.abs(diffMs) / 86400000);
    const label = overdueDays > 1 ? `Просрочено ${overdueDays}д.` : 'Просрочено';
    return {label, cls:'overdue', time};
  }
  // Сколько полных дней осталось
  const diffDays = Math.floor(diffMs / 86400000);
  if(diffDays === 0) return {label:'Сегодня', cls:'today', time};
  if(diffDays === 1) return {label:'Завтра',  cls:'', time};
  return {label: next.toLocaleDateString('ru',{day:'numeric',month:'short'}), cls:'', time};
}

// ── CRM RENDER ──
function renderCRM(){
  COLS.forEach(col => {
    const items = cards.filter(c => c.col === col);
    document.getElementById('cnt-'+col).textContent = items.length;
    const body = document.getElementById('body-'+col);
    if(!items.length){
      body.innerHTML = '<div class="empty">Перетащите карточку<br>или нажмите «+ Добавить»</div>';
    } else {
      body.innerHTML = items.map(cardHTML).join('');
      body.querySelectorAll('.card').forEach(el => {
        el.addEventListener('dragstart', e => { dragId=el.dataset.id; el.classList.add('dragging'); e.stopPropagation(); });
        el.addEventListener('dragend',   e => { el.classList.remove('dragging'); dragId=null; });
      });
    }
  });
  document.getElementById('s-total').textContent = cards.length;
  document.getElementById('s-warm').textContent  = cards.filter(c=>c.col==='warm').length;
  document.getElementById('s-done').textContent  = cards.filter(c=>c.col==='done').length;
}

function cardHTML(c){
  const tz   = c.timezone ? `<div class="card-row"><i class="ico">🕐</i><span>${c.timezone}</span></div>` : '';
  const gis  = c.gis ? `<div class="card-row"><i class="ico">🗺</i><a href="${c.gis}" target="_blank" onclick="event.stopPropagation()">Открыть 2ГИС</a></div>` : '';
  const meta = (tz||gis) ? `<div class="card-meta">${tz}${gis}</div>` : '';
  const note = c.note ? `<div class="card-note">${c.note}</div>` : '';
  const nl   = nextLabel(c);
  const nextHtml = nl ? `<div class="card-next ${nl.cls}">📅 ${nl.label}${nl.time?' в '+nl.time:''}</div>` : '';
  return `<div class="card" draggable="true" data-id="${c.id}" onclick="viewCard('${c.id}')">
    <div class="card-top">
      <div class="card-company">${c.company}</div>
      <div class="card-actions">
        <button class="cbtn cbtn-e" onclick="event.stopPropagation();editCard('${c.id}')">✎</button>
        <button class="cbtn cbtn-d" onclick="event.stopPropagation();deleteCard('${c.id}')">✕</button>
      </div>
    </div>
    ${meta}${note}${nextHtml}
  </div>`;
}

// ── ЗАДАЧНИК RENDER ──
function renderTasks(){
  const now = new Date();

  const withDate = cards.filter(c => c.nextDate).map(c => {
    const next   = parseEkbDateTime(c.nextDate, c.nextTime);
    const diffMs = next - now; // отрицательное = просрочено
    return {...c, _next: next, _diff: diffMs};
  }).sort((a, b) => a._next - b._next);

  // Конец текущей недели (воскресенье 23:59:59 Екатеринбург)
  const ekbNow     = new Date(new Date().toLocaleString('en-US', {timeZone:'Asia/Yekaterinburg'}));
  const dayOfWeek  = ekbNow.getDay();
  const daysToSun  = dayOfWeek === 0 ? 0 : 7 - dayOfWeek;
  const weekEnd    = parseEkbDateTime(
    new Date(ekbNow.getFullYear(), ekbNow.getMonth(), ekbNow.getDate() + daysToSun)
      .toISOString().slice(0,10),
    '23:59'
  );
  // Конец текущего месяца
  const monthEnd   = parseEkbDateTime(
    new Date(ekbNow.getFullYear(), ekbNow.getMonth() + 1, 0).toISOString().slice(0,10),
    '23:59'
  );
  // Завтра — граница (через 24ч от начала сегодня по Екб)
  const todayStart = parseEkbDateTime(ekbNow.toISOString().slice(0,10), '00:00');
  const tomorrowStart = new Date(todayStart.getTime() + 86400000);
  const dayAfterStart = new Date(todayStart.getTime() + 86400000 * 2);

  const sections = [
    {key:'overdue',  label:'Просроченные',   cls:'ts-overdue',  items: withDate.filter(c => c._diff < 0)},
    {key:'today',    label:'Сегодня',        cls:'ts-today',    items: withDate.filter(c => c._diff >= 0 && c._next < tomorrowStart)},
    {key:'tomorrow', label:'Завтра',         cls:'ts-tomorrow', items: withDate.filter(c => c._next >= tomorrowStart && c._next < dayAfterStart)},
    {key:'week',     label:'На этой неделе', cls:'ts-week',     items: withDate.filter(c => c._next >= dayAfterStart && c._next <= weekEnd)},
    {key:'month',    label:'В этом месяце',  cls:'ts-month',    items: withDate.filter(c => c._next > weekEnd && c._next <= monthEnd)},
    {key:'later',    label:'Позже',          cls:'ts-later',    items: withDate.filter(c => c._next > monthEnd)},
  ].filter(s => s.items.length > 0);

  const noDate = cards.filter(c => !c.nextDate);

  const noDateSection = noDate.length ? [`
    <div class="task-section ts-later">
      <div class="task-section-head">
        <div class="task-section-title"><span class="ts-dot"></span>Без даты контакта</div>
        <span class="task-section-cnt">${noDate.length}</span>
      </div>
      <div class="task-list">
        ${noDate.map(c => `
          <div class="task-item" onclick="viewCard('${c.id}')">
            <div class="task-item-top">
              <div class="task-company">${c.company}</div>
              <span class="task-time" style="background:rgba(100,100,100,.15);color:var(--muted)">Не задано</span>
            </div>
            <div class="task-col-badge">📂 ${COL_LABELS[c.col]||c.col}</div>
            ${c.note ? `<div class="task-note">${c.note}</div>` : ''}
          </div>`).join('')}
      </div>
    </div>`] : [];

  if(!sections.length && !noDateSection.length){
    document.getElementById('tasks-grid').innerHTML =
      '<div style="grid-column:1/-1;text-align:center;padding:60px;color:var(--dim);font-size:14px">Нет клиентов.<br>Добавьте карточки в CRM — они появятся здесь.</div>';
    return;
  }

  document.getElementById('tasks-grid').innerHTML = [
    ...sections.map(s => `
      <div class="task-section ${s.cls}">
        <div class="task-section-head">
          <div class="task-section-title"><span class="ts-dot"></span>${s.label}</div>
          <span class="task-section-cnt">${s.items.length}</span>
        </div>
        <div class="task-list">
          ${s.items.map(c => taskItemHTML(c, s.cls)).join('')}
        </div>
      </div>`),
    ...noDateSection
  ].join('');
}

function taskItemHTML(c, cls){
  const time  = c.nextTime || '';
  const date  = c._next.toLocaleDateString('ru',{day:'numeric',month:'short',timeZone:'Asia/Yekaterinburg'});
  const diffMs = c._diff;
  let label;
  if(diffMs < 0){
    const d = Math.ceil(Math.abs(diffMs) / 86400000);
    label = d > 1 ? `${d}д. назад` : 'Просрочено';
  } else {
    const diffDays = Math.floor(diffMs / 86400000);
    label = diffDays === 0 ? 'Сегодня' : diffDays === 1 ? 'Завтра' : date;
  }
  const note = c.note ? `<div class="task-note">${c.note}</div>` : '';
  return `<div class="task-item" onclick="viewCard('${c.id}')">
    <div class="task-item-top">
      <div class="task-company">${c.company}</div>
      <span class="task-time">${label}${time?' '+time:''}</span>
    </div>
    <div class="task-col-badge">📂 ${COL_LABELS[c.col]||c.col}</div>
    ${note}
  </div>`;
}

// ── VIEW ──
window.viewCard = function(id){
  const c = cards.find(x=>x.id===id);
  if(!c) return;
  document.getElementById('v-company').textContent = c.company;
  document.getElementById('v-sphere').innerHTML = c.sphere ? `<span class="view-sphere">${c.sphere}</span>` : '';
  const nl = nextLabel(c);
  const fields = [
    c.phone      && ['📞','Телефон',`<a href="tel:${c.phone}">${c.phone}</a>`],
    c.address    && ['📍','Адрес', c.address],
    c.timezone   && ['🕐','Время от Екатеринбурга', c.timezone],
    c.site       && ['🌐','Сайт',`<a href="${c.site}" target="_blank">${c.site}</a>`],
    c.siteStatus && ['💻','Статус сайта', STATUS_LABELS[c.siteStatus]||c.siteStatus],
    c.gis        && ['🗺','2ГИС',`<a href="${c.gis}" target="_blank">Открыть в 2ГИС</a>`],
    nl           && ['📅','Следующий контакт', `${nl.label}${nl.time?' в '+nl.time:''}`],
    ['📂','Статус', COL_LABELS[c.col]||c.col],
  ].filter(Boolean);
  document.getElementById('v-fields').innerHTML = fields.map(([ico,lbl,val])=>`
    <div class="vf"><i class="vf-ico">${ico}</i>
    <div><div class="vf-label">${lbl}</div><div class="vf-val">${val}</div></div></div>`).join('');
  document.getElementById('v-note').innerHTML = c.note ? `<div class="view-note">${c.note}</div>` : '';
  document.getElementById('v-edit-btn').onclick = ()=>{ closeViewDirect(); editCard(id); };
  document.getElementById('v-del-btn').onclick  = ()=>{ closeViewDirect(); deleteCard(id); };
  document.getElementById('view-overlay').classList.add('on');
};
window.closeView       = e => { if(e.target===document.getElementById('view-overlay')) closeViewDirect(); };
window.closeViewDirect = () => document.getElementById('view-overlay').classList.remove('on');

// ── CRUD ──
window.openModal = (col='new') => {
  editId = null;
  document.getElementById('modal-title').textContent = 'Новый клиент';
  clearForm();
  document.getElementById('f-col').value = col;
  document.getElementById('overlay').classList.add('on');
  setTimeout(()=>document.getElementById('f-company').focus(), 50);
};
window.editCard = id => {
  const c = cards.find(x=>x.id===id);
  if(!c) return;
  editId = id;
  document.getElementById('modal-title').textContent = 'Редактировать клиента';
  document.getElementById('f-company').value     = c.company||'';
  document.getElementById('f-phone').value       = c.phone||'';
  document.getElementById('f-sphere').value      = c.sphere||'';
  document.getElementById('f-address').value     = c.address||'';
  document.getElementById('f-timezone').value    = c.timezone||'';
  document.getElementById('f-site').value        = c.site||'';
  document.getElementById('f-site-status').value = c.siteStatus||'';
  document.getElementById('f-gis').value         = c.gis||'';
  document.getElementById('f-next-date').value   = c.nextDate||'';
  document.getElementById('f-next-time').value   = c.nextTime||'10:00';
  document.getElementById('f-col').value         = c.col||'new';
  document.getElementById('f-note').value        = c.note||'';
  document.getElementById('overlay').classList.add('on');
};
window.deleteCard = async id => {
  if(!confirm('Удалить карточку?')) return;
  await deleteDoc(doc(db,'cards',id));
};
window.saveCard = async () => {
  const company = document.getElementById('f-company').value.trim();
  if(!company){ alert('Укажите название компании'); return; }
  const id = editId || Date.now().toString(36)+Math.random().toString(36).slice(2);
  await setDoc(doc(db,'cards',id), {
    company,
    phone:      document.getElementById('f-phone').value.trim(),
    sphere:     document.getElementById('f-sphere').value.trim(),
    address:    document.getElementById('f-address').value.trim(),
    timezone:   document.getElementById('f-timezone').value.trim(),
    site:       document.getElementById('f-site').value.trim(),
    siteStatus: document.getElementById('f-site-status').value,
    gis:        document.getElementById('f-gis').value.trim(),
    nextDate:   document.getElementById('f-next-date').value,
    nextTime:   document.getElementById('f-next-time').value,
    col:        document.getElementById('f-col').value,
    note:       document.getElementById('f-note').value.trim(),
  });
  closeModalDirect();
};
function clearForm(){
  ['f-company','f-phone','f-sphere','f-address','f-timezone','f-site','f-gis','f-note','f-next-date'].forEach(id=>{
    document.getElementById(id).value='';
  });
  document.getElementById('f-next-time').value='10:00';
  document.getElementById('f-site-status').value='';
  document.getElementById('f-col').value='new';
}
window.closeModal       = e => { if(e.target===document.getElementById('overlay')) closeModalDirect(); };
window.closeModalDirect = () => { document.getElementById('overlay').classList.remove('on'); editId=null; };

// ── DRAG & DROP ──
window.onDragOver  = e => { e.preventDefault(); e.currentTarget.classList.add('over'); };
window.onDragLeave = e => e.currentTarget.classList.remove('over');
window.onDrop = async (e, col) => {
  e.preventDefault();
  e.currentTarget.classList.remove('over');
  if(!dragId) return;
  const c = cards.find(x=>x.id===dragId);
  if(c) await setDoc(doc(db,'cards',dragId), {...c, col});
};

document.addEventListener('keydown', e => {
  if(e.key==='Escape'){ closeModalDirect(); closeViewDirect(); }
});
</script>
</body>
</html>
