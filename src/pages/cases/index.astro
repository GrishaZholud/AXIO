---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseCard from '../../components/CaseCard.astro';
import CtaForm from '../../components/CtaForm.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { cases, casesAreDemo } from '../../data/cases';
import { site } from '../../lib/site';
import { breadcrumbSchema, type Crumb } from '../../lib/schema';

const crumbs: Crumb[] = [
  { name: 'Главная', href: '/' },
  { name: 'Кейсы', href: '/cases' },
];
const schema = [breadcrumbSchema(crumbs)];
---

<BaseLayout
  title="Кейсы AXIO — реальные результаты digital-проектов"
  description="Кейсы digital-агентства AXIO: сайты, SEO, таргет, маркетплейсы, карты и внедрение ИИ. Измеримые результаты проектов с цифрами и описанием работы."
  path="/cases"
  image="/images/og/home.jpg"
  schema={schema}
>
  <section class="cases-hero">
    <div class="container">
      <div class="cases-hero__crumbs"><Breadcrumbs crumbs={crumbs} /></div>
      <span class="eyebrow">Кейсы</span>
      <h1 class="h1 cases-hero__title">Результаты, которые можно измерить</h1>
      <p class="lead cases-hero__lead">
        Не обещания, а цифры реальных проектов — собранные в аналитике клиентов.
        От сайтов и SEO до маркетплейсов и внедрения ИИ.
      </p>
      {
        casesAreDemo && (
          <p class="cases-hero__demo">
            Кейсы — демонстрационные примеры оформления результатов.
          </p>
        )
      }
    </div>
  </section>

  <section class="section cases-list">
    <div class="container">
      <div class="cases-list__grid">
        {cases.map((c) => <CaseCard study={c} />)}
      </div>
    </div>
  </section>

  <CtaForm title="Хотите такой же результат?" text="Расскажите про задачу — предложим решение и оценим сроки. Бесплатно, в течение часа." />
</BaseLayout>

<style>
  .cases-hero {
    padding-top: clamp(7rem, 14vh, 9.5rem);
    padding-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }
  .cases-hero__crumbs {
    margin-bottom: 1.75rem;
  }
  .cases-hero__title {
    margin-block: 1.25rem;
    max-width: 16ch;
  }
  .cases-hero__lead {
    max-width: 60ch;
  }
  .cases-hero__demo {
    margin-top: 1.25rem;
    display: inline-block;
    font-size: 0.8rem;
    color: var(--text-muted);
    padding: 0.5rem 0.9rem;
    border: 1px dashed var(--border);
    border-radius: 999px;
  }
  .cases-list {
    padding-top: clamp(1rem, 2vw, 1.5rem);
  }
  .cases-list__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }
</style>
