---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Icon from '../components/Icon.astro';
import CtaForm from '../components/CtaForm.astro';
import { site } from '../lib/site';
import { services } from '../data/services';
import { breadcrumbSchema, type Crumb } from '../lib/schema';

const crumbs: Crumb[] = [
  { name: 'Главная', href: '/' },
  { name: 'О нас', href: '/about' },
];

// AboutPage node, linked to the global Organization entity (injected by <Seo>).
const aboutSchema = {
  '@type': 'AboutPage',
  url: `${site.url}/about`,
  name: 'О компании AXIO',
  description:
    'AXIO — digital-агентство полного цикла в Екатеринбурге. С 2024 года помогаем бизнесу расти в интернете: сайты, SEO, реклама, маркетплейсы, карты и внедрение ИИ.',
  mainEntity: { '@id': `${site.url}/#organization` },
};
const schema = [breadcrumbSchema(crumbs), aboutSchema];

const stats = [
  { value: '2 года', label: 'на рынке digital' },
  { value: '150+', label: 'проектов запущено' },
  { value: '7', label: 'направлений работы' },
  { value: '100%', label: 'уникальный подход' },
];

const values = [
  {
    icon: 'target',
    title: 'Результат, не процесс',
    text: 'Оцениваем работу по цифрам, а не по количеству действий.',
  },
  {
    icon: 'message',
    title: 'Прозрачность',
    text: 'Отчёты, объяснения и честный диалог на каждом этапе.',
  },
  {
    icon: 'spark',
    title: 'Экспертиза',
    text: 'Узкие специалисты в каждом направлении, а не универсальные менеджеры.',
  },
  {
    icon: 'flow',
    title: 'Долгосрочность',
    text: 'Строим партнёрство, а не разовые проекты.',
  },
];

// Every service is a direction — link each to its landing page (internal linking).
const directions = services.map((s, i) => ({
  n: String(i + 1).padStart(2, '0'),
  icon: s.icon,
  label: s.label,
  desc: s.short,
  href: `/${s.slug}`,
}));

const team = [
  { dept: 'Разработка', role: 'Front-end разработчик' },
  { dept: 'Разработка', role: 'Back-end разработчик' },
  { dept: 'Дизайн', role: 'UI/UX-дизайнер' },
  { dept: 'Продвижение', role: 'SEO-специалист' },
  { dept: 'Реклама', role: 'Таргетолог' },
  { dept: 'Маркетплейсы', role: 'Менеджер маркетплейсов' },
  { dept: 'Контент', role: 'Копирайтер' },
  { dept: 'Карты и отзывы', role: 'Специалист по картам' },
  { dept: 'Искусственный интеллект', role: 'Специалист по ИИ' },
];
---

<BaseLayout
  title="О компании AXIO — digital-агентство полного цикла в Екатеринбурге"
  description="AXIO — digital-агентство полного цикла в Екатеринбурге. С 2024 года помогаем бизнесу расти: сайты, SEO, таргет, маркетплейсы, карты и внедрение ИИ. 150+ проектов, узкие специалисты, работа на результат."
  path="/about"
  schema={schema}
>
  <section class="about-hero">
    <div class="container">
      <div class="about-hero__crumbs"><Breadcrumbs crumbs={crumbs} /></div>
      <div class="about-hero__grid">
        <div class="about-hero__text">
          <span class="eyebrow">О компании</span>
          <h1 class="h1 about-hero__title">Мы — команда, которая делает digital результатом</h1>
          <p class="lead about-hero__lead">
            AXIO — digital-агентство полного цикла. С 2024 года помогаем бизнесу
            расти в интернете: от разработки сайтов до продвижения на маркетплейсах
            и в поисковых системах.
          </p>
        </div>
        <figure class="about-hero__media">
          <img
            src="/images/about/office.webp"
            alt="Офис digital-агентства AXIO в бизнес-центре «Сенатор», Екатеринбург"
            width="1200"
            height="1400"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
          <figcaption class="about-hero__badge">AXIO · Екатеринбург</figcaption>
        </figure>
      </div>
      <dl class="about-stats">
        {stats.map((s) => (
          <div class="about-stats__item">
            <dt>{s.value}</dt>
            <dd>{s.label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <section class="section about-mission" data-theme="dark" aria-labelledby="mission-title">
    <div class="container container--narrow">
      <span class="eyebrow">Миссия</span>
      <h2 class="h2" id="mission-title">Зачем мы здесь</h2>
      <p class="about-mission__lead">
        Мы верим, что каждый бизнес заслуживает сильного присутствия в интернете.
        Наша задача — не просто сделать «красивый сайт» или «запустить рекламу»,
        а выстроить систему, которая приносит реальные заявки и клиентов.
      </p>
      <p class="about-mission__text">
        Работаем как партнёры: погружаемся в задачи бизнеса, предлагаем честные
        решения и несём ответственность за результат.
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="values-title">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Принципы</span>
        <h2 class="h2" id="values-title">Как мы работаем</h2>
      </div>
      <div class="about-values">
        {values.map((v) => (
          <div class="value-card">
            <span class="value-card__icon"><Icon name={v.icon} size={22} /></span>
            <h3 class="value-card__title">{v.title}</h3>
            <p class="value-card__text">{v.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section about-dirs" aria-labelledby="dirs-title">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Чем занимаемся</span>
        <h2 class="h2" id="dirs-title">Наши направления</h2>
      </div>
      <div class="about-dirs__grid">
        {directions.map((d) => (
          <a href={d.href} class="dir-card">
            <span class="dir-card__top">
              <span class="dir-card__icon"><Icon name={d.icon} size={22} /></span>
              <span class="dir-card__n">{d.n}</span>
              <svg class="dir-card__arrow" width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
                <path d="M4 9h9M9 5l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
            <span class="dir-card__label">{d.label}</span>
            <span class="dir-card__desc">{d.desc}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="team-title">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Люди</span>
        <h2 class="h2" id="team-title">Кто делает результат</h2>
        <p class="section-head__note">
          Над каждым проектом работают узкие специалисты — не универсальные
          менеджеры «на все руки».
        </p>
      </div>
      <ul class="about-team">
        {team.map((m) => (
          <li class="team-card">
            <span class="team-card__dept">{m.dept}</span>
            <span class="team-card__role">{m.role}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section about-env" aria-labelledby="env-title">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Среда</span>
        <h2 class="h2" id="env-title">Где мы работаем</h2>
        <p class="section-head__note">
          Наш офис — в бизнес-центре «Сенатор» на ул. Хомякова, 14 в центре
          Екатеринбурга.
        </p>
      </div>
      <div class="about-env__grid">
        <figure class="env-photo">
          <img
            src="/images/about/building.webp"
            alt="Бизнес-центр «Сенатор» на улице Хомякова, 14 — офис агентства AXIO в Екатеринбурге"
            width="1600"
            height="900"
            loading="lazy"
            decoding="async"
          />
          <figcaption>БЦ «Сенатор», ул. Хомякова, 14</figcaption>
        </figure>
        <figure class="env-photo">
          <img
            src="/images/about/office-wide.webp"
            alt="Рабочее пространство офиса digital-агентства AXIO"
            width="1600"
            height="900"
            loading="lazy"
            decoding="async"
          />
          <figcaption>Наш офис изнутри</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <CtaForm
    title="Обсудим ваш проект"
    text="Заполните форму — свяжемся в течение часа и предложим стратегию под ваши задачи."
  />
</BaseLayout>

<style>
  .about-hero {
    padding-top: clamp(2.5rem, 5vw, 3.5rem);
    padding-bottom: clamp(2rem, 4vw, 3rem);
  }
  .about-hero__crumbs {
    margin-bottom: 1.75rem;
  }
  .about-hero__grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .about-hero__text {
    min-width: 0;
  }
  .about-hero__title {
    margin-block: 1rem 1.1rem;
    max-width: 18ch;
  }
  .about-hero__lead {
    max-width: 52ch;
    margin-bottom: 0;
  }
  .about-hero__media {
    position: relative;
    margin: 0;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-md);
  }
  .about-hero__media img {
    width: 100%;
    aspect-ratio: 6 / 7;
    object-fit: cover;
    display: block;
  }
  .about-hero__badge {
    position: absolute;
    left: 1.25rem;
    bottom: 1.25rem;
    padding: 0.6rem 1.1rem;
    background: var(--gold-deep);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    border-radius: 999px;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.18);
  }
  @media (max-width: 820px) {
    .about-hero__grid {
      grid-template-columns: 1fr;
    }
    .about-hero__media {
      max-width: 460px;
    }
    .about-hero__media img {
      aspect-ratio: 16 / 11;
    }
  }
  .about-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1.5rem;
    margin-top: clamp(2rem, 4vw, 3rem);
    padding-top: clamp(1.75rem, 3vw, 2.25rem);
    border-top: 1px solid var(--border);
  }
  .about-stats__item dt {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--gold-deep);
    line-height: 1;
  }
  .about-stats__item dd {
    margin: 0.5rem 0 0;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .about-mission__lead {
    font-size: clamp(1.15rem, 2vw, 1.4rem);
    line-height: 1.55;
    color: var(--on-dark);
    margin: 1.25rem 0 1rem;
  }
  .about-mission__text {
    color: var(--on-dark-muted);
    line-height: 1.7;
    max-width: 62ch;
  }
  .about-mission .eyebrow {
    color: var(--gold);
  }
  .about-mission .h2 {
    color: var(--on-dark);
  }

  .section-head {
    margin-bottom: clamp(1.75rem, 3vw, 2.5rem);
  }
  .section-head__note {
    margin-top: 0.85rem;
    color: var(--text-muted);
    max-width: 56ch;
    line-height: 1.6;
  }

  .about-values {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }
  .value-card {
    padding: 1.6rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .value-card__icon {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    color: var(--gold-deep);
    background: var(--gold-soft);
    border-radius: 12px;
    margin-bottom: 1rem;
  }
  .value-card__title {
    font-size: 1.1rem;
    color: var(--ink);
    margin-bottom: 0.5rem;
  }
  .value-card__text {
    font-size: 0.92rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* Flex (not grid) so the final row stretches to fill — no empty cells with 11 items. */
  .about-dirs__grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .about-dirs__grid .dir-card {
    flex: 1 1 290px;
  }
  .dir-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.4rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: border-color 200ms ease, box-shadow 200ms ease;
  }
  .dir-card:hover {
    border-color: var(--gold);
    box-shadow: var(--shadow-md);
  }
  .dir-card__top {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 0.35rem;
  }
  .dir-card__icon {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    color: var(--gold-deep);
    background: var(--gold-soft);
    border-radius: 10px;
  }
  .dir-card__n {
    font-size: 0.85rem;
    font-weight: 800;
    color: var(--gold);
    flex-shrink: 0;
  }
  .dir-card__arrow {
    margin-left: auto;
    color: var(--text-faint);
    flex-shrink: 0;
    transition: transform 0.25s var(--ease), color 0.25s var(--ease);
  }
  .dir-card:hover .dir-card__arrow {
    transform: translateX(3px);
    color: var(--gold-deep);
  }
  .dir-card__label {
    font-weight: 700;
    color: var(--ink);
  }
  .dir-card__desc {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .about-team {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  @media (max-width: 860px) {
    .about-team {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 540px) {
    .about-team {
      grid-template-columns: 1fr;
    }
  }
  .team-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1.3rem 1.4rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    border-left: 2px solid var(--gold);
  }
  .team-card__dept {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--gold-deep);
  }
  .team-card__role {
    font-weight: 600;
    color: var(--ink);
  }

  .about-env__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  .env-photo {
    margin: 0;
    display: flex;
    flex-direction: column;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface);
  }
  .env-photo img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }
  .env-photo figcaption {
    padding: 0.85rem 1.1rem;
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  @media (max-width: 640px) {
    .about-env__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
