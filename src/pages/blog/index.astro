---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaForm from '../../components/CtaForm.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { posts } from '../../data/posts';
import { site } from '../../lib/site';
import { breadcrumbSchema, type Crumb } from '../../lib/schema';

const crumbs: Crumb[] = [
  { name: 'Главная', href: '/' },
  { name: 'Блог', href: '/blog' },
];

// Newest first
const sorted = [...posts].sort(
  (a, b) => +new Date(b.datePublished) - +new Date(a.datePublished)
);

const fmt = (d: string) =>
  new Date(d).toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });

const blogSchema = {
  '@type': 'Blog',
  '@id': `${site.url}/blog`,
  name: 'Блог AXIO',
  url: `${site.url}/blog`,
  publisher: { '@id': `${site.url}/#organization` },
  blogPost: sorted.map((p) => ({
    '@type': 'BlogPosting',
    headline: p.title,
    url: `${site.url}/blog/${p.slug}`,
    datePublished: p.datePublished,
    dateModified: p.dateModified,
  })),
};
const schema = [breadcrumbSchema(crumbs), blogSchema];
---

<BaseLayout
  title="Блог AXIO — digital-маркетинг, SEO, маркетплейсы и ИИ"
  description="Блог digital-агентства AXIO: разборы по SEO, таргету, маркетплейсам, картам и внедрению ИИ. Реальные кейсы, практические гайды и тренды 2025 года."
  path="/blog"
  image="/images/og/home.jpg"
  schema={schema}
>
  <section class="blog-hero">
    <div class="container">
      <div class="blog-hero__crumbs"><Breadcrumbs crumbs={crumbs} /></div>
      <span class="eyebrow">Блог</span>
      <h1 class="h1 blog-hero__title">Разборы, гайды и кейсы</h1>
      <p class="lead blog-hero__lead">
        Делимся тем, что работает в digital прямо сейчас: SEO, таргет,
        маркетплейсы, карты и внедрение ИИ — без воды и на реальных примерах.
      </p>
    </div>
  </section>

  <section class="section blog-list">
    <div class="container">
      <div class="blog-grid">
        {sorted.map((p) => (
          <a href={`/blog/${p.slug}`} class="post-card">
            <div class="post-card__media">
              <img src={p.cover} alt={p.title} width="1200" height="675" loading="lazy" decoding="async" />
              <span class="post-card__cat">{p.category}</span>
            </div>
            <div class="post-card__body">
              <h2 class="post-card__title">{p.title}</h2>
              <p class="post-card__excerpt">{p.excerpt}</p>
              <p class="post-card__meta">
                <span>{fmt(p.datePublished)}</span>
                <span aria-hidden="true">·</span>
                <span>{p.readingTime}</span>
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaForm title="Нужна помощь с задачей из статьи?" text="Разберём вашу ситуацию и предложим решение. Бесплатно, в течение часа." />
</BaseLayout>

<style>
  .blog-hero {
    padding-top: clamp(7rem, 14vh, 9.5rem);
    padding-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }
  .blog-hero__crumbs {
    margin-bottom: 1.75rem;
  }
  .blog-hero__title {
    margin-block: 1rem 1.1rem;
  }
  .blog-hero__lead {
    max-width: 60ch;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }
  .post-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 200ms ease, box-shadow 200ms ease;
  }
  @media (hover: hover) and (pointer: fine) {
    .post-card:hover {
      border-color: var(--gold);
      box-shadow: var(--shadow-md);
    }
  }
  .post-card__media {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--cream-2, #f4f1eb);
  }
  .post-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 400ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  @media (hover: hover) and (pointer: fine) {
    .post-card:hover .post-card__media img {
      transform: scale(1.04);
    }
  }
  .post-card__cat {
    position: absolute;
    left: 0.9rem;
    top: 0.9rem;
    padding: 0.35rem 0.75rem;
    background: var(--gold-deep);
    color: #fff;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    border-radius: 999px;
  }
  .post-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: 1.5rem;
    flex: 1;
  }
  .post-card__title {
    font-size: 1.2rem;
    line-height: 1.3;
    color: var(--ink);
  }
  .post-card__excerpt {
    font-size: 0.92rem;
    color: var(--text-muted);
    line-height: 1.55;
  }
  .post-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 0.5rem;
    font-size: 0.82rem;
    color: var(--text-faint);
  }
</style>
