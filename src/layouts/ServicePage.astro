---
// Shared template for every service landing page. Thin per-service files pass
// structured content; this renders the hero, AEO direct-answer block, pricing
// tiers, process, related cases, FAQ and CTA — plus Service/FAQ/Breadcrumb
// schema. Keeps all 11 service pages consistent and DRY.
import BaseLayout from './BaseLayout.astro';
import ServiceHeroBg from '../components/ServiceHeroBg.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Faq from '../components/Faq.astro';
import CtaForm from '../components/CtaForm.astro';
import CaseCard from '../components/CaseCard.astro';
import Guarantees from '../components/Guarantees.astro';
import TechBar from '../components/TechBar.astro';
import Reviews from '../components/Reviews.astro';
import OtherServices from '../components/OtherServices.astro';
import { cases } from '../data/cases';
import { realReviews } from '../data/reviews';
import { faqsByTopic, type FaqTopic } from '../data/faqs';
import { site } from '../lib/site';
import {
  serviceSchema,
  faqSchema,
  breadcrumbSchema,
  howToSchema,
  reviewSchema,
  speakableSchema,
  type Crumb,
} from '../lib/schema';

export interface Plan {
  name: string;
  price: string;
  priceNote?: string;
  /** Delivery time, e.g. "7–12 рабочих дней" */
  duration?: string;
  for: string;
  /** Roles on the project ("Ваша команда") */
  team?: string[];
  /** What's included ("Что входит") */
  features: string[];
  /** What the client gets ("Что вы получаете на выходе") */
  outcome?: string[];
  featured?: boolean;
}
/** A comparison-matrix row: feature label + one cell per tariff (✓ / — / text) */
export interface CompareRow {
  feature: string;
  values: string[];
}
export interface Stage {
  n: string;
  t: string;
  d: string;
}
export interface Props {
  slug: string;
  eyebrow: string;
  seoTitle: string;
  seoDescription: string;
  serviceName: string;
  serviceType?: string;
  heroTitle: string;
  heroLead: string;
  heroQuote?: string;
  answerTitle: string;
  answerBody: string[];
  plans?: Plan[];
  plansTitle?: string;
  planNote?: string;
  /** Optional comparison matrix (rows of features × tariffs) */
  comparison?: CompareRow[];
  comparisonTitle?: string;
  stages: Stage[];
  stagesTitle?: string;
  /** Filter related cases by these service tags */
  relatedTags?: string[];
  faqTopic: FaqTopic;
  faqTitle?: string;
  faqEyebrow?: string;
  ctaTitle?: string;
  ctaText?: string;
}

const p = Astro.props;
const hasPlans = (p.plans?.length ?? 0) > 0;
const faqs = faqsByTopic[p.faqTopic];
const related = (p.relatedTags?.length
  ? cases.filter((c) => c.tags.some((t) => p.relatedTags!.includes(t)))
  : cases
).slice(0, 4);

const crumbs: Crumb[] = [
  { name: 'Главная', href: '/' },
  { name: 'Услуги', href: '/#services-title' },
  { name: p.serviceName, href: `/${p.slug}` },
];

const schema = [
  serviceSchema({
    name: p.serviceName,
    description: p.seoDescription,
    url: `${site.url}/${p.slug}`,
    serviceType: p.serviceType ?? p.serviceName,
  }),
  howToSchema({ name: `Как мы работаем: ${p.serviceName}`, steps: p.stages }),
  ...reviewSchema(realReviews),
  faqSchema(faqs),
  breadcrumbSchema(crumbs),
  speakableSchema(`${site.url}/${p.slug}`),
];
---

<BaseLayout
  title={p.seoTitle}
  description={p.seoDescription}
  path={`/${p.slug}`}
  image={`/images/og/${p.slug}.jpg`}
  heroHeader={true}
  schema={schema}
>
  <!-- Hero -->
  <section class="svc-hero" data-theme="dark">
    <ServiceHeroBg motif={p.slug} />
    <div class="container svc-hero__inner">
      <div class="svc-hero__crumbs"><Breadcrumbs crumbs={crumbs} dark /></div>
      <span class="eyebrow">{p.eyebrow}</span>
      <h1 class="h1 svc-hero__title">{p.heroTitle}</h1>
      <p class="lead svc-hero__lead">{p.heroLead}</p>
      <div class="svc-hero__actions">
        {hasPlans ? (
          <>
            <a href="#plans" class="btn btn--gold btn--lg">Смотреть тарифы</a>
            <button type="button" class="btn btn--ghost btn--lg" data-lead-open>Бесплатная консультация</button>
          </>
        ) : (
          <>
            <button type="button" class="btn btn--gold btn--lg" data-lead-open>Бесплатная консультация</button>
            <a href="/cases" class="btn btn--ghost btn--lg">Смотреть кейсы</a>
          </>
        )}
      </div>
      {p.heroQuote && <blockquote class="svc-hero__quote">{p.heroQuote}</blockquote>}
    </div>
  </section>

  <!-- Direct-answer (AEO) -->
  <section class="section answer">
    <div class="container container--narrow">
      <h2 class="h2 reveal">{p.answerTitle}</h2>
      {p.answerBody.map((para, i) => (
        <p class:list={['reveal', i === 0 ? 'answer__lead' : 'answer__text']}>{para}</p>
      ))}
    </div>
  </section>

  <!-- Optional page-specific sections (e.g. AI page) -->
  <slot />

  <TechBar />

  <Guarantees />

  <!-- Plans -->
  {hasPlans && (
  <section class="section plans" id="plans" data-theme="dark" aria-labelledby="plans-title">
    <div class="container">
      <div class="section-head section-head--center reveal">
        <span class="eyebrow">Тарифы</span>
        <h2 class="h2" id="plans-title">{p.plansTitle ?? 'Выберите подходящий план'}</h2>
      </div>
      <div class="plans__grid">
        {
          p.plans!.map((plan) => (
            <article class:list={['plan reveal', { 'plan--featured': plan.featured }]}>
              {plan.featured && <span class="plan__badge">Популярный</span>}
              <h3 class="plan__name">{plan.name}</h3>
              <p class="plan__price">{plan.price}</p>
              {plan.priceNote && <p class="plan__pricenote">{plan.priceNote}</p>}
              {plan.duration && (
                <p class="plan__duration">
                  <svg width="14" height="14" viewBox="0 0 16 16" aria-hidden="true"><circle cx="8" cy="8" r="6.4" fill="none" stroke="currentColor" stroke-width="1.4"/><path d="M8 4.6V8l2.4 1.6" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                  срок: {plan.duration}
                </p>
              )}
              <p class="plan__for">{plan.for}</p>
              {plan.team && plan.team.length > 0 && (
                <div class="plan__team">
                  <span class="plan__sub">Ваша команда</span>
                  <ul>{plan.team.map((m) => <li>{m}</li>)}</ul>
                </div>
              )}
              <div class="plan__block">
                <span class="plan__sub">Что входит</span>
                <ul class="plan__features">
                  {plan.features.map((f) => <li>{f}</li>)}
                </ul>
              </div>
              {plan.outcome && plan.outcome.length > 0 && (
                <div class="plan__block">
                  <span class="plan__sub">Что вы получаете</span>
                  <ul class="plan__outcome">
                    {plan.outcome.map((o) => <li>{o}</li>)}
                  </ul>
                </div>
              )}
              <button
                type="button"
                class:list={['btn', plan.featured ? 'btn--gold' : 'btn--ghost']}
                data-lead-open
              >
                Обсудить тариф
              </button>
            </article>
          ))
        }
      </div>
      {p.planNote && <p class="plans__note">{p.planNote}</p>}
    </div>
  </section>
  )}

  <!-- Comparison table -->
  {
    p.comparison && p.comparison.length > 0 && (
      <section class="section compare" aria-labelledby="compare-title">
        <div class="container">
          <div class="section-head section-head--center reveal">
            <span class="eyebrow">Сравнение</span>
            <h2 class="h2" id="compare-title">{p.comparisonTitle ?? 'Сравнение тарифов'}</h2>
          </div>
          <div class="compare__scroll reveal">
            <table class="compare__table">
              <thead>
                <tr>
                  <th scope="col">Что входит</th>
                  {p.plans.map((plan) => (
                    <th scope="col" class:list={{ 'is-featured': plan.featured }}>
                      <span class="compare__tier">{plan.name}</span>
                      <span class="compare__price">{plan.price}</span>
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {p.comparison.map((row) => (
                  <tr>
                    <th scope="row">{row.feature}</th>
                    {row.values.map((v, i) => (
                      <td class:list={{ 'is-featured': p.plans[i]?.featured }}>
                        {v === '✓' ? (
                          <svg class="compare__yes" width="18" height="18" viewBox="0 0 18 18" aria-label="есть"><path d="M4 9.5 7.5 13 14 5.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        ) : v === '—' ? (
                          <span class="compare__no" aria-label="нет">—</span>
                        ) : (
                          <span class="compare__val">{v}</span>
                        )}
                      </td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </section>
    )
  }

  <!-- Stages -->
  <section class="section" aria-labelledby="stages-title">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">Как мы работаем</span>
        <h2 class="h2" id="stages-title">{p.stagesTitle ?? 'Этапы работы'}</h2>
      </div>
      <ol class="stages reveal">
        {
          p.stages.map((s) => (
            <li class="stage">
              <span class="stage__n">{s.n}</span>
              <div>
                <h3 class="stage__t">{s.t}</h3>
                <p class="stage__d">{s.d}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- Related cases -->
  {
    related.length > 0 && (
      <section class="section cases-rel" data-theme="dark" aria-labelledby="cases-rel-title">
        <div class="container">
          <div class="section-head reveal">
            <span class="eyebrow">Результаты</span>
            <h2 class="h2" id="cases-rel-title">Кейсы по направлению</h2>
          </div>
          <div class="cases-rel__grid reveal">
            {related.map((c) => <CaseCard study={c} />)}
          </div>
        </div>
      </section>
    )
  }

  <Reviews dark />

  <OtherServices current={p.slug} />

  <Faq
    items={faqs}
    title={p.faqTitle ?? 'Частые вопросы'}
    eyebrow={p.faqEyebrow ?? 'FAQ'}
  />
  <CtaForm
    preselect={p.slug}
    title={p.ctaTitle ?? 'Обсудим ваш проект'}
    text={p.ctaText ?? 'Заполните форму — свяжемся в течение часа и предложим решение под ваши задачи.'}
  />
</BaseLayout>

<style>
  .svc-hero {
    position: relative;
    overflow: hidden;
    background: var(--ink);
    padding-top: clamp(7rem, 14vh, 9.5rem);
    padding-bottom: clamp(3.5rem, 8vw, 6rem);
  }
  .svc-hero__inner {
    position: relative;
    z-index: 1;
    max-width: 820px;
  }
  .svc-hero__crumbs {
    margin-bottom: 1.75rem;
  }
  .svc-hero .eyebrow {
    color: var(--gold);
  }
  .svc-hero__title {
    color: var(--on-dark);
    margin-block: 1.25rem;
  }
  .svc-hero__lead {
    color: var(--on-dark-muted);
    max-width: 56ch;
  }
  .svc-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2.25rem;
  }
  .svc-hero__quote {
    margin-top: 2.75rem;
    padding-left: 1.25rem;
    border-left: 2px solid var(--gold);
    color: var(--on-dark);
    font-size: 1.05rem;
    font-style: italic;
    max-width: 60ch;
  }

  .answer__lead {
    font-size: clamp(1.15rem, 1.05rem + 0.5vw, 1.4rem);
    color: var(--ink);
    line-height: 1.5;
    margin-top: 1rem;
  }
  .answer__text {
    margin-top: 1.25rem;
    color: var(--text-muted);
  }

  .plans .eyebrow,
  .plans .section-head h2 {
    color: var(--on-dark);
  }
  .plans .eyebrow {
    color: var(--gold);
  }
  .plans__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
    align-items: start;
  }
  .plan {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 2rem 1.75rem;
    background: var(--ink-2);
    border: 1px solid var(--gold-line);
    border-radius: var(--radius);
  }
  .plan--featured {
    background: linear-gradient(180deg, rgba(196, 166, 117, 0.14), rgba(196, 166, 117, 0.03));
    border-color: var(--gold);
    box-shadow: var(--shadow-gold);
  }
  .plan__badge {
    position: absolute;
    top: -0.7rem;
    left: 1.75rem;
    background: var(--gold);
    color: var(--ink);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
  }
  .plan__name {
    font-size: 1.3rem;
    color: var(--on-dark);
  }
  .plan__price {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--gold);
    letter-spacing: -0.02em;
  }
  .plan__pricenote {
    font-size: 0.82rem;
    color: var(--on-dark-faint);
    margin-top: -0.6rem;
  }
  .plan__for {
    color: var(--on-dark-muted);
    font-size: 0.9rem;
    min-height: 2.7em;
  }
  .plan__features {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 1.25rem;
    display: grid;
    gap: 0.6rem;
  }
  .plan__features li {
    position: relative;
    padding-left: 1.6rem;
    color: var(--on-dark-muted);
    font-size: 0.9rem;
    line-height: 1.45;
  }
  .plan__features li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.45em;
    width: 0.85rem;
    height: 0.5rem;
    border-left: 2px solid var(--gold);
    border-bottom: 2px solid var(--gold);
    transform: rotate(-45deg);
  }
  .plan .btn {
    margin-top: auto;
    width: 100%;
  }
  .plans__note {
    margin-top: 1.5rem;
    text-align: center;
    font-size: 0.85rem;
    color: var(--on-dark-faint);
  }
  .plan__duration {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    color: var(--gold);
    margin-top: -0.4rem;
  }
  .plan__sub {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--on-dark-faint);
    margin-bottom: 0.55rem;
  }
  .plan__team {
    padding-top: 0.85rem;
    border-top: 1px solid var(--gold-line);
  }
  .plan__team ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
  }
  .plan__team li {
    font-size: 0.8rem;
    color: var(--on-dark);
    padding: 0.25rem 0.6rem;
    background: var(--gold-soft);
    border-radius: 999px;
  }
  .plan__block {
    padding-top: 0.4rem;
  }
  .plan__outcome {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.55rem;
  }
  .plan__outcome li {
    position: relative;
    padding-left: 1.6rem;
    color: var(--on-dark-muted);
    font-size: 0.88rem;
    line-height: 1.45;
  }
  .plan__outcome li::before {
    content: '★';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--gold);
    font-size: 0.85rem;
  }

  /* ---- Comparison table ---- */
  .compare__scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: var(--radius);
    border: 1px solid var(--line);
  }
  .compare__table {
    width: 100%;
    border-collapse: collapse;
    min-width: 640px;
    background: var(--surface);
  }
  .compare__table th,
  .compare__table td {
    padding: 0.9rem 1.1rem;
    text-align: center;
    vertical-align: middle;
    border-bottom: 1px solid var(--line);
  }
  .compare__table thead th {
    vertical-align: bottom;
    border-bottom: 2px solid var(--border);
  }
  .compare__table tbody th {
    text-align: left;
    font-weight: 500;
    color: var(--ink);
    font-size: 0.92rem;
  }
  .compare__table thead th:first-child {
    text-align: left;
    font-size: 0.72rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--text-faint);
    font-weight: 700;
  }
  .compare__tier {
    display: block;
    font-weight: 700;
    font-size: 1rem;
    color: var(--ink);
  }
  .compare__price {
    display: block;
    font-size: 0.82rem;
    color: var(--gold-deep);
    margin-top: 0.15rem;
  }
  .compare__table tbody tr:last-child th,
  .compare__table tbody tr:last-child td {
    border-bottom: 0;
  }
  .compare__table tbody tr:nth-child(odd) td,
  .compare__table tbody tr:nth-child(odd) th {
    background: var(--cream);
  }
  /* Keep ✓ / — / text vertically aligned on one line across every cell */
  .compare__yes,
  .compare__no,
  .compare__val {
    display: inline-block;
    vertical-align: middle;
    line-height: 20px;
  }
  .compare__yes {
    color: var(--gold-deep);
  }
  .compare__no {
    color: var(--text-faint);
  }
  .compare__val {
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .compare__table th.is-featured,
  .compare__table td.is-featured {
    background: var(--gold-soft) !important;
  }

  .stages {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem 2.5rem;
  }
  .stage {
    display: flex;
    gap: 1.25rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--line);
  }
  .stage__n {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--gold);
    letter-spacing: -0.03em;
  }
  .stage__t {
    font-size: 1.15rem;
    color: var(--ink);
    margin-bottom: 0.4rem;
  }
  .stage__d {
    color: var(--text-muted);
    font-size: 0.93rem;
    line-height: 1.55;
  }

  .cases-rel .eyebrow,
  .cases-rel .section-head h2 {
    color: var(--on-dark);
  }
  .cases-rel .eyebrow {
    color: var(--gold);
  }
  .cases-rel__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }
</style>
